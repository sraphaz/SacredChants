# Local development with Vercel (vercel dev).
# Copy to .env.local and fill in. Do not commit .env.local.
#
# Run: npm run dev:vercel
# Then open http://localhost:3000/contribute/

# Same origin for site + API when running vercel dev (single port)
SITE_ORIGIN=http://localhost:3000
BASE_PATH=/
API_ORIGIN=http://localhost:3000
CONTRIBUTE_ORIGIN=http://localhost:3000

# From your GitHub OAuth App (same as production, or a separate dev app)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Personal Access Token with repo scope (for creating PRs)
GITHUB_TOKEN=

# Any long random string (e.g. openssl rand -hex 32)
SESSION_SECRET=

# Repo where contribution PRs are opened
GITHUB_REPO_OWNER=sraphaz
GITHUB_REPO_NAME=SacredChants
