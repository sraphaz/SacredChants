---
import BaseLayout from './BaseLayout.astro';
import type { Chant } from '../content/schemas/chant';
import type { Locale } from '../i18n/strings';
import { chantMetaDescription } from '../utils/chant-page';

interface Props {
  chant: Chant;
  locale?: Locale;
}

const { chant, locale } = Astro.props;
const descriptionForMeta = chantMetaDescription(chant.description, locale);
---

<BaseLayout title={chant.title} description={descriptionForMeta} locale={locale}>
  <article class="chant-page py-page px-page-x" role="article" aria-label={chant.title}>
    <div class="chant-page__inner chant-page__inner--measure mx-auto">
      <slot />
    </div>
  </article>
</BaseLayout>
