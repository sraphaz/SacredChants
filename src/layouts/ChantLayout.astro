---
import BaseLayout from './BaseLayout.astro';
import type { Chant } from '../content/schemas/chant';

interface Props {
  chant: Chant;
}

const { chant } = Astro.props;
---

<BaseLayout title={chant.title} description={chant.description?.en ?? chant.description?.pt ?? ''}>
  <article class="chant-page py-page px-page-x" role="article" aria-label={chant.title}>
    <div class="chant-page__inner chant-page__inner--measure mx-auto">
      <slot />
    </div>
  </article>
</BaseLayout>
