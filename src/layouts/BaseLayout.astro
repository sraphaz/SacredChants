---
import '../styles/global.css';
import { ui, type Locale } from '../i18n/strings';

const BASE = import.meta.env.BASE_URL;

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
}

const { title, description = 'A living library of sacred sound traditions.' } = Astro.props;
const tEn = ui.en;
const tPt = ui.pt;
---

<!doctype html>
<html lang="en" data-locale="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${BASE}favicon.svg`} />
    <meta name="description" content={description} />
    <title>{title} | Sacred Chants</title>
    <script is:inline>
      (function() {
        var STORAGE = 'sacred-chants-';
        var root = document.documentElement;
        root.dataset.theme = localStorage.getItem(STORAGE + 'theme') || 'dark';
        root.dataset.fontSize = localStorage.getItem(STORAGE + 'fontSize') || 'medium';
        root.dataset.fontFamily = localStorage.getItem(STORAGE + 'fontFamily') || 'sans';
        root.dataset.spacing = localStorage.getItem(STORAGE + 'spacing') || 'normal';
        var verseTint = localStorage.getItem(STORAGE + 'verseTint') || 'default';
        if (verseTint) root.dataset.verseTint = verseTint;
        var textColor = localStorage.getItem(STORAGE + 'textColor') || 'default';
        if (textColor) root.dataset.textColor = textColor;
        var bg = localStorage.getItem(STORAGE + 'bg') || 'default';
        if (bg) root.dataset.bg = bg;
        var savedLang = localStorage.getItem(STORAGE + 'lang');
        var q = new URLSearchParams(window.location.search);
        var urlLang = q.get('lang');
        if (savedLang && !urlLang) {
          q.set('lang', savedLang);
          window.location.replace(window.location.pathname + (q.toString() ? '?' + q.toString() : ''));
          return;
        }
        var locale = urlLang === 'pt' ? 'pt' : (savedLang === 'pt' ? 'pt' : 'en');
        root.dataset.locale = locale;
        root.lang = locale === 'pt' ? 'pt' : 'en';
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="sc-header backdrop-blur">
      <nav class="sc-header__nav max-w-content mx-auto px-page-x py-4 flex flex-wrap items-center gap-4">
        <a href={BASE} class="locale-en font-serif text-xl sc-header-a shrink-0"><span class="locale-en">Sacred Chants</span></a>
        <a href={`${BASE}?lang=pt`} class="locale-pt font-serif text-xl sc-header-a shrink-0"><span class="locale-pt">Sacred Chants</span></a>
        <div class="sc-header__menu-wrap flex-1 flex justify-center min-w-0">
          <ul class="sc-header__menu flex flex-wrap items-center justify-center gap-6 text-sm">
          <li><a href={BASE} class="locale-en">{tEn.nav.home}</a><a href={`${BASE}?lang=pt`} class="locale-pt">{tPt.nav.home}</a></li>
          <li><a href={`${BASE}chants`} class="locale-en">{tEn.nav.chants}</a><a href={`${BASE}chants?lang=pt`} class="locale-pt">{tPt.nav.chants}</a></li>
          <li><a href={`${BASE}traditions`} class="locale-en">{tEn.nav.traditions}</a><a href={`${BASE}traditions?lang=pt`} class="locale-pt">{tPt.nav.traditions}</a></li>
          <li><a href={`${BASE}knowledge`} class="locale-en">{tEn.nav.knowledge}</a><a href={`${BASE}knowledge?lang=pt`} class="locale-pt">{tPt.nav.knowledge}</a></li>
          <li><a href={`${BASE}contribute`} class="locale-en">{tEn.nav.contribute}</a><a href={`${BASE}contribute?lang=pt`} class="locale-pt">{tPt.nav.contribute}</a></li>
          <li><a href={`${BASE}settings`} class="locale-en">{tEn.nav.settings}</a><a href={`${BASE}settings?lang=pt`} class="locale-pt">{tPt.nav.settings}</a></li>
          <li><span style="color: var(--sc-text-subtle)">|</span></li>
          <li><a href={Astro.url.pathname + '?lang=pt'} class="locale-en">{tEn.lang.pt}</a><a href={Astro.url.pathname + '?lang=en'} class="locale-pt">{tPt.lang.en}</a></li>
          </ul>
        </div>
      </nav>
    </header>
    <main class="flex-1 sc-main-with-header">
      <slot />
    </main>
    <footer class="sc-footer border-t py-8 mt-auto">
      <div class="max-w-content mx-auto px-page-x text-center text-sm">
        <p class="locale-en">Sacred Chants — {tEn.home.tagline}</p>
        <p class="locale-pt">Sacred Chants — {tPt.home.tagline}</p>
        <p class="mt-1" style="color: var(--sc-text-subtle)">Open source · No ads · Contemplative</p>
      </div>
    </footer>
  </body>
</html>
