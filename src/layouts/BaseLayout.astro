---
import '../styles/global.css';
import { ui, getLocaleFromUrl, langQuery, SUPPORTED_LOCALES, type Locale } from '../i18n/strings';
import { getFullBase, getBasePath } from '../utils/base';
import NavLinkList from '../components/NavLinkList.astro';
import FooterTaglines from '../components/FooterTaglines.astro';

const FULL_BASE = getFullBase(Astro.url);
const basePath = getBasePath();
const pathname = Astro.url.pathname;
const pathWithBase = pathname.startsWith(basePath) || pathname === basePath.replace(/\/$/, '') ? pathname : basePath.replace(/\/$/, '') + (pathname.startsWith('/') ? pathname : '/' + pathname);
const FULL_PATH = Astro.url.origin + (pathWithBase.startsWith('/') ? pathWithBase : '/' + pathWithBase);

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
}

const { title, description = 'Human heritage in sound. A living library of sacred chant — preserving access to the inner states of consciousness that sacred sound opens.', locale: propsLocale } = Astro.props;
const tEn = ui.en;
const tPt = ui.pt;
const tEs = ui.es;
const tIt = ui.it;
const resolvedLocale = propsLocale ?? getLocaleFromUrl(Astro.url.searchParams);
const initialLocale: Locale = resolvedLocale === 'pt' || resolvedLocale === 'es' || resolvedLocale === 'it' ? resolvedLocale : 'en';

const navItems = [
  { path: '', labelByLocale: { en: tEn.nav.home, pt: tPt.nav.home, es: tEs.nav.home, it: tIt.nav.home } },
  { path: 'chants/', labelByLocale: { en: tEn.nav.chants, pt: tPt.nav.chants, es: tEs.nav.chants, it: tIt.nav.chants } },
  { path: 'traditions/', labelByLocale: { en: tEn.nav.traditions, pt: tPt.nav.traditions, es: tEs.nav.traditions, it: tIt.nav.traditions } },
  { path: 'knowledge/', labelByLocale: { en: tEn.nav.knowledge, pt: tPt.nav.knowledge, es: tEs.nav.knowledge, it: tIt.nav.knowledge } },
  { path: 'contribute/', labelByLocale: { en: tEn.nav.contribute, pt: tPt.nav.contribute, es: tEs.nav.contribute, it: tIt.nav.contribute } },
  { path: 'settings/', labelByLocale: { en: tEn.nav.settings, pt: tPt.nav.settings, es: tEs.nav.settings, it: tIt.nav.settings } },
];
---

<!doctype html>
<html lang={initialLocale} data-locale={initialLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href={FULL_BASE} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${FULL_BASE}favicon.png`} />
    <link rel="apple-touch-icon" href={`${FULL_BASE}apple-touch-icon.png`} />
    <link rel="manifest" href={`${FULL_BASE}manifest.webmanifest`} />
    <meta name="theme-color" content="#1a1a1a" />
    <meta name="description" content={description} />
    <title>{title} | Sacred Chants</title>
    <script is:inline src={`${FULL_BASE}scripts/init-theme-locale.js`}></script>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="sc-header backdrop-blur" id="sc-header">
      <nav class="sc-header__nav w-full flex flex-nowrap items-center gap-3 sc-header__nav-pad" aria-label="Main">
        <div class="sc-header__brand shrink-0">
          <a href={FULL_BASE} class="locale-en font-serif text-base sc-header-a whitespace-nowrap"><span class="locale-en">Sacred Chants</span></a>
          <a href={`${FULL_BASE}?lang=pt`} class="locale-pt font-serif text-base sc-header-a whitespace-nowrap"><span class="locale-pt">Sacred Chants</span></a>
          <a href={`${FULL_BASE}?lang=es`} class="locale-es font-serif text-base sc-header-a whitespace-nowrap"><span class="locale-es">Sacred Chants</span></a>
          <a href={`${FULL_BASE}?lang=it`} class="locale-it font-serif text-base sc-header-a whitespace-nowrap"><span class="locale-it">Sacred Chants</span></a>
        </div>
        <div class="sc-header__menu-inline">
          <ul class="sc-header__menu">
            <NavLinkList fullBase={FULL_BASE} items={navItems} />
            <li class="sc-header__menu-lang-row">
              <label for="sc-locale-select" class="sr-only">Language</label>
              <select id="sc-locale-select" class="sc-locale-select" aria-label="Language" data-initial-locale={initialLocale} data-supported-locales={JSON.stringify([...SUPPORTED_LOCALES])}>
                <option value="en" selected={initialLocale === 'en' ? true : undefined}>EN</option>
                <option value="pt" selected={initialLocale === 'pt' ? true : undefined}>PT</option>
                <option value="es" selected={initialLocale === 'es' ? true : undefined}>ES</option>
                <option value="it" selected={initialLocale === 'it' ? true : undefined}>IT</option>
              </select>
            </li>
          </ul>
        </div>
        <button
          type="button"
          class="sc-header__menu-toggle"
          id="sc-header-menu-toggle"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="sc-header-drawer"
        >
          <span class="sc-header__menu-toggle-icon" aria-hidden="true"></span>
        </button>
      </nav>
    </header>
    <div class="sc-header__drawer-backdrop" id="sc-header-drawer-backdrop" aria-hidden="true"></div>
    <div class="sc-header__drawer" id="sc-header-drawer" role="navigation" aria-label="Site menu">
      <ul class="sc-header__drawer-menu">
        <NavLinkList fullBase={FULL_BASE} items={navItems} />
        <li class="sc-header__menu-lang-row">
          <label for="sc-locale-select-drawer" class="sr-only">Language</label>
          <select id="sc-locale-select-drawer" class="sc-locale-select" aria-label="Language" data-initial-locale={initialLocale} data-supported-locales={JSON.stringify([...SUPPORTED_LOCALES])}>
            <option value="en" selected={initialLocale === 'en' ? true : undefined}>EN</option>
            <option value="pt" selected={initialLocale === 'pt' ? true : undefined}>PT</option>
            <option value="es" selected={initialLocale === 'es' ? true : undefined}>ES</option>
            <option value="it" selected={initialLocale === 'it' ? true : undefined}>IT</option>
          </select>
        </li>
      </ul>
    </div>
    <script src={`${FULL_BASE}scripts/drawer.js`}></script>
    <script src={`${FULL_BASE}scripts/locale-select.js`}></script>
    <script is:inline>
      (function () {
        if (!('serviceWorker' in navigator)) return;
        if (location.protocol !== 'https:' && location.hostname !== 'localhost') return;
        var base = document.querySelector('base');
        var swUrl = base ? new URL('sw.js', base.href).href : '/sw.js';
        window.addEventListener('load', function () {
          navigator.serviceWorker.register(swUrl).catch(function () {});
        });
      })();
    </script>
    <main class="flex-1 sc-main-with-header">
      <slot />
    </main>
    <footer class="sc-footer border-t py-8 mt-auto">
      <div class="max-w-content mx-auto px-page-x text-center text-sm">
        <FooterTaglines taglineByLocale={{ en: tEn.home.tagline, pt: tPt.home.tagline, es: tEs.home.tagline, it: tIt.home.tagline }} />
        <p class="mt-1" style="color: var(--sc-text-subtle)">
          <a href="https://github.com/sraphaz/SacredChants" target="_blank" rel="noopener noreferrer" class="hover:underline" style="color: var(--sc-text-subtle)">GitHub</a>
          <span class="mx-1">·</span> Open source · No ads · Human heritage · Contemplative
        </p>
      </div>
    </footer>
    <script type="module" src={`${FULL_BASE}scripts/save-offline.js`}></script>
  </body>
</html>
