---
import '../styles/global.css';
import { ui, getLocaleFromUrl, type Locale } from '../i18n/strings';

const BASE = import.meta.env.BASE_URL || '/';
const BASE_SLASH = BASE.endsWith('/') ? BASE : BASE + '/';
const ORIGIN = Astro.url.origin;
const FULL_BASE = ORIGIN + (BASE_SLASH.startsWith('/') ? BASE_SLASH : '/' + BASE_SLASH);
const pathname = Astro.url.pathname;
const pathWithBase = pathname.startsWith(BASE_SLASH) || pathname === BASE_SLASH.replace(/\/$/, '') ? pathname : BASE_SLASH.replace(/\/$/, '') + (pathname.startsWith('/') ? pathname : '/' + pathname);
const FULL_PATH = ORIGIN + (pathWithBase.startsWith('/') ? pathWithBase : '/' + pathWithBase);

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
}

const { title, description = 'Human heritage in sound. A living library of sacred chant — preserving access to the inner states of consciousness that sacred sound opens.', locale: propsLocale } = Astro.props;
const tEn = ui.en;
const tPt = ui.pt;
const tEs = ui.es;
const tIt = ui.it;
const initialLocale: Locale = propsLocale ?? getLocaleFromUrl(Astro.url.searchParams);
const q = (l: Locale) => l === 'en' ? '' : `?lang=${l}`;
---

<!doctype html>
<html lang={initialLocale} data-locale={initialLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href={FULL_BASE} />
    <link rel="icon" type="image/svg+xml" href={`${FULL_BASE}favicon.svg`} />
    <meta name="description" content={description} />
    <title>{title} | Sacred Chants</title>
    <script is:inline>
      (function() {
        var STORAGE = 'sacred-chants-';
        var root = document.documentElement;
        root.dataset.theme = localStorage.getItem(STORAGE + 'theme') || 'dark';
        root.dataset.fontSize = localStorage.getItem(STORAGE + 'fontSize') || 'medium';
        root.dataset.fontFamily = localStorage.getItem(STORAGE + 'fontFamily') || 'sans';
        root.dataset.spacing = localStorage.getItem(STORAGE + 'spacing') || 'normal';
        var verseTint = localStorage.getItem(STORAGE + 'verseTint') || 'default';
        if (verseTint) root.dataset.verseTint = verseTint;
        var textColor = localStorage.getItem(STORAGE + 'textColor') || 'default';
        if (textColor) root.dataset.textColor = textColor;
        var bg = localStorage.getItem(STORAGE + 'bg') || 'default';
        if (bg) root.dataset.bg = bg;
        var savedLang = localStorage.getItem(STORAGE + 'lang');
        var q = new URLSearchParams(window.location.search);
        var urlLang = q.get('lang');
        if (savedLang && !urlLang) {
          q.set('lang', savedLang);
          window.location.replace(window.location.pathname + (q.toString() ? '?' + q.toString() : ''));
          return;
        }
        var allowed = ['en', 'pt', 'pt-br', 'es', 'it'];
        if (urlLang && allowed.indexOf(urlLang) !== -1) {
          try { localStorage.setItem(STORAGE + 'lang', urlLang === 'pt-br' ? 'pt' : urlLang); } catch (e) {}
        }
        var locale = urlLang === 'pt-br' || urlLang === 'pt' ? 'pt' : (urlLang === 'es' ? 'es' : (urlLang === 'it' ? 'it' : (savedLang === 'pt' ? 'pt' : (savedLang === 'es' ? 'es' : (savedLang === 'it' ? 'it' : 'en')))));
        root.dataset.locale = locale;
        root.lang = locale;
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="sc-header backdrop-blur" id="sc-header">
      <nav class="sc-header__nav w-full flex flex-nowrap items-center gap-3 sc-header__nav-pad" aria-label="Main">
        <div class="sc-header__brand shrink-0">
          <a href={FULL_BASE} class="locale-en font-serif text-base sc-header-a whitespace-nowrap"><span class="locale-en">Sacred Chants</span></a>
          <a href={`${FULL_BASE}?lang=pt`} class="locale-pt font-serif text-base sc-header-a whitespace-nowrap"><span class="locale-pt">Sacred Chants</span></a>
          <a href={`${FULL_BASE}?lang=es`} class="locale-es font-serif text-base sc-header-a whitespace-nowrap"><span class="locale-es">Sacred Chants</span></a>
          <a href={`${FULL_BASE}?lang=it`} class="locale-it font-serif text-base sc-header-a whitespace-nowrap"><span class="locale-it">Sacred Chants</span></a>
        </div>
        <div class="sc-header__menu-inline">
          <ul class="sc-header__menu">
          <li><a href={FULL_BASE} class="locale-en">{tEn.nav.home}</a><a href={`${FULL_BASE}?lang=pt`} class="locale-pt">{tPt.nav.home}</a><a href={`${FULL_BASE}?lang=es`} class="locale-es">{tEs.nav.home}</a><a href={`${FULL_BASE}?lang=it`} class="locale-it">{tIt.nav.home}</a></li>
          <li><a href={`${FULL_BASE}chants/`} class="locale-en">{tEn.nav.chants}</a><a href={`${FULL_BASE}chants/?lang=pt`} class="locale-pt">{tPt.nav.chants}</a><a href={`${FULL_BASE}chants/${q('es')}`} class="locale-es">{tEs.nav.chants}</a><a href={`${FULL_BASE}chants/${q('it')}`} class="locale-it">{tIt.nav.chants}</a></li>
          <li><a href={`${FULL_BASE}traditions/`} class="locale-en">{tEn.nav.traditions}</a><a href={`${FULL_BASE}traditions/?lang=pt`} class="locale-pt">{tPt.nav.traditions}</a><a href={`${FULL_BASE}traditions/${q('es')}`} class="locale-es">{tEs.nav.traditions}</a><a href={`${FULL_BASE}traditions/${q('it')}`} class="locale-it">{tIt.nav.traditions}</a></li>
          <li><a href={`${FULL_BASE}knowledge/`} class="locale-en">{tEn.nav.knowledge}</a><a href={`${FULL_BASE}knowledge/?lang=pt`} class="locale-pt">{tPt.nav.knowledge}</a><a href={`${FULL_BASE}knowledge/${q('es')}`} class="locale-es">{tEs.nav.knowledge}</a><a href={`${FULL_BASE}knowledge/${q('it')}`} class="locale-it">{tIt.nav.knowledge}</a></li>
          <li><a href={`${FULL_BASE}contribute/`} class="locale-en">{tEn.nav.contribute}</a><a href={`${FULL_BASE}contribute/?lang=pt`} class="locale-pt">{tPt.nav.contribute}</a><a href={`${FULL_BASE}contribute/${q('es')}`} class="locale-es">{tEs.nav.contribute}</a><a href={`${FULL_BASE}contribute/${q('it')}`} class="locale-it">{tIt.nav.contribute}</a></li>
          <li><a href={`${FULL_BASE}settings/`} class="locale-en">{tEn.nav.settings}</a><a href={`${FULL_BASE}settings/?lang=pt`} class="locale-pt">{tPt.nav.settings}</a><a href={`${FULL_BASE}settings/${q('es')}`} class="locale-es">{tEs.nav.settings}</a><a href={`${FULL_BASE}settings/${q('it')}`} class="locale-it">{tIt.nav.settings}</a></li>
          <li class="sc-header__menu-lang-row">
            <label for="sc-locale-select" class="sr-only">Language</label>
            <select id="sc-locale-select" class="sc-locale-select" aria-label="Language">
              <option value="en" selected={initialLocale === 'en'}>EN</option>
              <option value="pt" selected={initialLocale === 'pt'}>PT</option>
              <option value="es" selected={initialLocale === 'es'}>ES</option>
              <option value="it" selected={initialLocale === 'it'}>IT</option>
            </select>
          </li>
          </ul>
        </div>
        <button
          type="button"
          class="sc-header__menu-toggle"
          id="sc-header-menu-toggle"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="sc-header-drawer"
        >
          <span class="sc-header__menu-toggle-icon" aria-hidden="true"></span>
        </button>
      </nav>
    </header>
    <div class="sc-header__drawer-backdrop" id="sc-header-drawer-backdrop" aria-hidden="true"></div>
    <div class="sc-header__drawer" id="sc-header-drawer" role="navigation" aria-label="Site menu">
      <ul class="sc-header__drawer-menu">
      <li><a href={FULL_BASE} class="locale-en">{tEn.nav.home}</a><a href={`${FULL_BASE}?lang=pt`} class="locale-pt">{tPt.nav.home}</a><a href={`${FULL_BASE}?lang=es`} class="locale-es">{tEs.nav.home}</a><a href={`${FULL_BASE}?lang=it`} class="locale-it">{tIt.nav.home}</a></li>
      <li><a href={`${FULL_BASE}chants/`} class="locale-en">{tEn.nav.chants}</a><a href={`${FULL_BASE}chants/?lang=pt`} class="locale-pt">{tPt.nav.chants}</a><a href={`${FULL_BASE}chants/${q('es')}`} class="locale-es">{tEs.nav.chants}</a><a href={`${FULL_BASE}chants/${q('it')}`} class="locale-it">{tIt.nav.chants}</a></li>
      <li><a href={`${FULL_BASE}traditions/`} class="locale-en">{tEn.nav.traditions}</a><a href={`${FULL_BASE}traditions/?lang=pt`} class="locale-pt">{tPt.nav.traditions}</a><a href={`${FULL_BASE}traditions/${q('es')}`} class="locale-es">{tEs.nav.traditions}</a><a href={`${FULL_BASE}traditions/${q('it')}`} class="locale-it">{tIt.nav.traditions}</a></li>
      <li><a href={`${FULL_BASE}knowledge/`} class="locale-en">{tEn.nav.knowledge}</a><a href={`${FULL_BASE}knowledge/?lang=pt`} class="locale-pt">{tPt.nav.knowledge}</a><a href={`${FULL_BASE}knowledge/${q('es')}`} class="locale-es">{tEs.nav.knowledge}</a><a href={`${FULL_BASE}knowledge/${q('it')}`} class="locale-it">{tIt.nav.knowledge}</a></li>
      <li><a href={`${FULL_BASE}contribute/`} class="locale-en">{tEn.nav.contribute}</a><a href={`${FULL_BASE}contribute/?lang=pt`} class="locale-pt">{tPt.nav.contribute}</a><a href={`${FULL_BASE}contribute/${q('es')}`} class="locale-es">{tEs.nav.contribute}</a><a href={`${FULL_BASE}contribute/${q('it')}`} class="locale-it">{tIt.nav.contribute}</a></li>
      <li><a href={`${FULL_BASE}settings/`} class="locale-en">{tEn.nav.settings}</a><a href={`${FULL_BASE}settings/?lang=pt`} class="locale-pt">{tPt.nav.settings}</a><a href={`${FULL_BASE}settings/${q('es')}`} class="locale-es">{tEs.nav.settings}</a><a href={`${FULL_BASE}settings/${q('it')}`} class="locale-it">{tIt.nav.settings}</a></li>
      <li class="sc-header__menu-lang-row">
        <label for="sc-locale-select-drawer" class="sr-only">Language</label>
        <select id="sc-locale-select-drawer" class="sc-locale-select" aria-label="Language">
          <option value="en" selected={initialLocale === 'en'}>EN</option>
          <option value="pt" selected={initialLocale === 'pt'}>PT</option>
          <option value="es" selected={initialLocale === 'es'}>ES</option>
          <option value="it" selected={initialLocale === 'it'}>IT</option>
        </select>
      </li>
      </ul>
    </div>
    <script is:inline>
      (function() {
        var header = document.getElementById('sc-header');
        var toggle = document.getElementById('sc-header-menu-toggle');
        var drawer = document.getElementById('sc-header-drawer');
        var backdrop = document.getElementById('sc-header-drawer-backdrop');
        if (!header || !toggle || !drawer) return;
        function open() {
          document.body.classList.add('sc-drawer-open');
          header.classList.add('sc-header--open');
          drawer.classList.add('sc-header__drawer--open');
          if (backdrop) backdrop.classList.add('sc-header__drawer-backdrop--open');
          toggle.setAttribute('aria-expanded', 'true');
          toggle.setAttribute('aria-label', 'Close menu');
        }
        function close() {
          document.body.classList.remove('sc-drawer-open');
          header.classList.remove('sc-header--open');
          drawer.classList.remove('sc-header__drawer--open');
          if (backdrop) backdrop.classList.remove('sc-header__drawer-backdrop--open');
          toggle.setAttribute('aria-expanded', 'false');
          toggle.setAttribute('aria-label', 'Open menu');
        }
        toggle.addEventListener('click', function() {
          if (drawer.classList.contains('sc-header__drawer--open')) close(); else open();
        });
        if (backdrop) backdrop.addEventListener('click', close);
        drawer.querySelectorAll('a').forEach(function(a) {
          a.addEventListener('click', close);
        });
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape' && drawer.classList.contains('sc-header__drawer--open')) close();
        });
      })();
    </script>
    <script is:inline>
      (function() {
        function onLocaleChange() {
          var lang = this.value;
          var path = window.location.pathname;
          window.location.href = path + (lang === 'en' ? '' : '?lang=' + lang);
        }
        var sel = document.getElementById('sc-locale-select');
        var selDrawer = document.getElementById('sc-locale-select-drawer');
        if (sel) sel.addEventListener('change', onLocaleChange);
        if (selDrawer) selDrawer.addEventListener('change', onLocaleChange);
      })();
    </script>
    <main class="flex-1 sc-main-with-header">
      <slot />
    </main>
    <footer class="sc-footer border-t py-8 mt-auto">
      <div class="max-w-content mx-auto px-page-x text-center text-sm">
        <p class="locale-en">Sacred Chants — {tEn.home.tagline}</p>
        <p class="locale-pt">Sacred Chants — {tPt.home.tagline}</p>
        <p class="locale-es">Sacred Chants — {tEs.home.tagline}</p>
        <p class="locale-it">Sacred Chants — {tIt.home.tagline}</p>
        <p class="mt-1" style="color: var(--sc-text-subtle)">
          <a href="https://github.com/sraphaz/SacredChants" target="_blank" rel="noopener noreferrer" class="hover:underline" style="color: var(--sc-text-subtle)">GitHub</a>
          <span class="mx-1">·</span> Open source · No ads · Human heritage · Contemplative
        </p>
      </div>
    </footer>
  </body>
</html>
