---
import type { ChantVerse as ChantVerseType, ChantLine } from '../content/schemas/chant';
import { ui, SUPPORTED_LOCALES } from '../i18n/strings';
import type { Locale } from '../i18n/strings';
import {
  lineTranslationForLocale,
  verseExplanationForLocale,
} from '../utils/chant-page';

interface Props {
  verse: ChantVerseType;
  line: ChantLine;
  /** Global line index for audio sync (0-based). */
  syncIndex: number;
  /** Show "Verse N" label (true for first line of verse). */
  showVerseLabel?: boolean;
  /** Show verse explanation (true for last line of verse). */
  showExplanation?: boolean;
}

const { verse, line, syncIndex, showVerseLabel = true, showExplanation = false } = Astro.props;
const tEn = ui.en;
const tPt = ui.pt;
const tEs = ui.es;
const tIt = ui.it;
const tHi = ui.hi;
const tAr = ui.ar;
/** Locales de tradução (mesma ordem que SUPPORTED_LOCALES / schema chant). */
const VERSE_LOCALES = [...SUPPORTED_LOCALES] as const;
const verseLabelByLocale: Record<(typeof VERSE_LOCALES)[number], string> = {
  en: tEn.chant.verse,
  pt: tPt.chant.verse,
  es: tEs.chant.verse,
  it: tIt.chant.verse,
  hi: tHi.chant.verse,
  ar: tAr.chant.verse,
};

function explanationHasAnyLocale(exp: ChantVerseType['explanation'] | undefined): boolean {
  if (!exp) return false;
  return SUPPORTED_LOCALES.some((loc) => {
    const s = exp[loc as keyof typeof exp];
    return typeof s === 'string' && s.trim().length > 0;
  });
}
---

<div
  class="verse-block prose-chant"
  data-verse={verse.order}
  data-sync-index={syncIndex}
  data-start-time={String(line.start)}
>
  {showVerseLabel && (
    <span class="verse-block__label uppercase tracking-label" aria-hidden="true">
      {VERSE_LOCALES.map((loc) => (
        <span class={`locale-${loc}`}>{verseLabelByLocale[loc]} {verse.order}</span>
      ))}
    </span>
  )}
  <p class="original" dir="auto" lang="und">
    {line.original}
  </p>
  <p class="transliteration" dir="ltr">
    {line.transliteration}
  </p>
  <div class="translations">
    {VERSE_LOCALES.map((loc) => {
      const text = lineTranslationForLocale(line.translations, loc as Locale);
      if (!text) return null;
      const own = line.translations[loc as keyof typeof line.translations];
      const usedOwn =
        typeof own === 'string' && own.trim().length > 0;
      const contentLang = usedOwn ? loc : 'en';
      return (
        <p
          class={`locale-${loc}`}
          data-lang={loc}
          lang={contentLang}
          dir={loc === 'ar' ? 'rtl' : undefined}
        >
          {text}
        </p>
      );
    })}
  </div>
  {showExplanation && explanationHasAnyLocale(verse.explanation) && (
    <>
      {VERSE_LOCALES.map((loc) => {
        const explanationText = verseExplanationForLocale(
          verse.explanation,
          loc as Locale
        );
        return explanationText ? (
          <div
            class={`verse-block__explanation locale-${loc}`}
            dir={loc === 'ar' ? 'rtl' : undefined}
          >
            <p>{explanationText}</p>
          </div>
        ) : null;
      })}
    </>
  )}
</div>
