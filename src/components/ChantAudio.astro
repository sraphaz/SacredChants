---
interface Props {
  src: string;
  title?: string;
  /** Id for lyric-sync script to attach timeupdate listener */
  id?: string;
}

const { src, title = 'Chant audio', id } = Astro.props;
---

{src && (
  <div class="chant-audio-box max-w-2xl mx-auto mb-10 px-4">
    <div class="rounded-lg p-4 flex items-center gap-4" style="background-color: var(--sc-border);">
      <audio
        id={id ?? undefined}
        controls
        preload="metadata"
        class="flex-1 min-w-0 h-10"
        aria-label={title}
      >
        <source src={src} type="audio/mpeg" />
        <source src={src} type="audio/ogg" />
        <p>Your browser does not support the audio element.</p>
      </audio>
    </div>
  </div>
)}
