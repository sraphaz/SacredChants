---
import type { Chant } from '../content/schemas/chant';

const BASE = import.meta.env.BASE_URL || '/';
const BASE_SLASH = BASE.endsWith('/') ? BASE : BASE + '/';
const FULL_BASE = Astro.url.origin + (BASE_SLASH.startsWith('/') ? BASE_SLASH : '/' + BASE_SLASH);

interface Props {
  chant: Chant;
}

const { chant } = Astro.props;
const descEn = typeof chant.description === 'string' ? chant.description : (chant.description?.en ?? chant.description?.pt ?? '');
const descPt = typeof chant.description === 'string' ? chant.description : (chant.description?.pt ?? chant.description?.en ?? '');
const desc = chant.description && typeof chant.description === 'object' ? chant.description as { en?: string; pt?: string; es?: string; it?: string } : {};
const descEs = desc.es ?? desc.en ?? desc.pt ?? '';
const descIt = desc.it ?? desc.en ?? desc.pt ?? '';
---

<div class="sc-card chant-card block rounded-lg border transition hover:shadow-sm" style="background-color: var(--sc-bg-elevated); border-color: var(--sc-border); --tw-shadow-color: var(--sc-border);">
  <a href={`${FULL_BASE}chants/${chant.slug}/`} class="locale-en block p-6">
    <p class="text-sm uppercase tracking-wider" style="color: var(--sc-text-muted)">{chant.tradition}</p>
    <div class="chant-card__title-row flex items-center gap-2 mt-1 flex-wrap">
      <h2 class="sc-card-title font-serif text-xl min-w-0 flex-1" style="color: var(--sc-text)">{chant.title}</h2>
      {chant.audio && chant.interpreter && <span class="text-sm flex-shrink-0" style="color: var(--sc-text-muted)">{chant.interpreter}</span>}
      {chant.audio && (
        <span class="chant-card__audio-icon flex-shrink-0" aria-hidden="true" title="Has audio">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--sc-text-muted)"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="2.5"/><circle cx="18" cy="16" r="2.5"/></svg>
        </span>
      )}
    </div>
    <p class="text-sm mt-2 line-clamp-2" style="color: var(--sc-text-muted)">{descEn}</p>
    {chant.tags && chant.tags.length > 0 && (
      <ul class="flex flex-wrap gap-1 mt-3">
        {chant.tags.slice(0, 3).map((tag) => (
          <li><span class="text-xs" style="color: var(--sc-text-subtle)">#{tag}</span></li>
        ))}
      </ul>
    )}
  </a>
  <a href={`${FULL_BASE}chants/${chant.slug}/?lang=pt`} class="locale-pt block p-6">
    <p class="text-sm uppercase tracking-wider" style="color: var(--sc-text-muted)">{chant.tradition}</p>
    <div class="chant-card__title-row flex items-center gap-2 mt-1 flex-wrap">
      <h2 class="sc-card-title font-serif text-xl min-w-0 flex-1" style="color: var(--sc-text)">{chant.title}</h2>
      {chant.audio && chant.interpreter && <span class="text-sm flex-shrink-0" style="color: var(--sc-text-muted)">{chant.interpreter}</span>}
      {chant.audio && (
        <span class="chant-card__audio-icon flex-shrink-0" aria-hidden="true" title="Tem áudio">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--sc-text-muted)"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="2.5"/><circle cx="18" cy="16" r="2.5"/></svg>
        </span>
      )}
    </div>
    <p class="text-sm mt-2 line-clamp-2" style="color: var(--sc-text-muted)">{descPt}</p>
    {chant.tags && chant.tags.length > 0 && (
      <ul class="flex flex-wrap gap-1 mt-3">
        {chant.tags.slice(0, 3).map((tag) => (
          <li><span class="text-xs" style="color: var(--sc-text-subtle)">#{tag}</span></li>
        ))}
      </ul>
    )}
  </a>
  <a href={`${FULL_BASE}chants/${chant.slug}/?lang=es`} class="locale-es block p-6">
    <p class="text-sm uppercase tracking-wider" style="color: var(--sc-text-muted)">{chant.tradition}</p>
    <div class="chant-card__title-row flex items-center gap-2 mt-1 flex-wrap">
      <h2 class="sc-card-title font-serif text-xl min-w-0 flex-1" style="color: var(--sc-text)">{chant.title}</h2>
      {chant.audio && chant.interpreter && <span class="text-sm flex-shrink-0" style="color: var(--sc-text-muted)">{chant.interpreter}</span>}
      {chant.audio && (
        <span class="chant-card__audio-icon flex-shrink-0" aria-hidden="true" title="Tiene audio">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--sc-text-muted)"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="2.5"/><circle cx="18" cy="16" r="2.5"/></svg>
        </span>
      )}
    </div>
    <p class="text-sm mt-2 line-clamp-2" style="color: var(--sc-text-muted)">{descEs}</p>
    {chant.tags && chant.tags.length > 0 && (
      <ul class="flex flex-wrap gap-1 mt-3">
        {chant.tags.slice(0, 3).map((tag) => (
          <li><span class="text-xs" style="color: var(--sc-text-subtle)">#{tag}</span></li>
        ))}
      </ul>
    )}
  </a>
  <a href={`${FULL_BASE}chants/${chant.slug}/?lang=it`} class="locale-it block p-6">
    <p class="text-sm uppercase tracking-wider" style="color: var(--sc-text-muted)">{chant.tradition}</p>
    <div class="chant-card__title-row flex items-center gap-2 mt-1 flex-wrap">
      <h2 class="sc-card-title font-serif text-xl min-w-0 flex-1" style="color: var(--sc-text)">{chant.title}</h2>
      {chant.audio && chant.interpreter && <span class="text-sm flex-shrink-0" style="color: var(--sc-text-muted)">{chant.interpreter}</span>}
      {chant.audio && (
        <span class="chant-card__audio-icon flex-shrink-0" aria-hidden="true" title="Ha audio">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--sc-text-muted)"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="2.5"/><circle cx="18" cy="16" r="2.5"/></svg>
        </span>
      )}
    </div>
    <p class="text-sm mt-2 line-clamp-2" style="color: var(--sc-text-muted)">{descIt}</p>
    {chant.tags && chant.tags.length > 0 && (
      <ul class="flex flex-wrap gap-1 mt-3">
        {chant.tags.slice(0, 3).map((tag) => (
          <li><span class="text-xs" style="color: var(--sc-text-subtle)">#{tag}</span></li>
        ))}
      </ul>
    )}
  </a>
</div>
