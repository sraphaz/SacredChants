---
import type { Chant } from '../content/schemas/chant';
import { langQuery, SUPPORTED_LOCALES } from '../i18n/strings';
import type { Locale } from '../i18n/strings';
import { getFullBase } from '../utils/base';

const FULL_BASE = getFullBase(Astro.url);

interface Props {
  chant: Chant;
}

const { chant } = Astro.props;

function getDescriptionByLocale(chantDesc: Chant['description'], locale: Locale): string {
  if (typeof chantDesc === 'string') return chantDesc;
  const obj =
    chantDesc && typeof chantDesc === 'object'
      ? (chantDesc as { en?: string; pt?: string; es?: string; it?: string; hi?: string; ar?: string })
      : {};
  switch (locale) {
    case 'en': return obj.en ?? obj.pt ?? '';
    case 'pt': return obj.pt ?? obj.en ?? '';
    case 'es': return obj.es ?? obj.en ?? obj.pt ?? '';
    case 'it': return obj.it ?? obj.en ?? obj.pt ?? '';
    case 'hi': return obj.hi ?? obj.en ?? obj.pt ?? '';
    case 'ar': return obj.ar ?? obj.en ?? obj.pt ?? '';
    default: return obj.en ?? obj.pt ?? '';
  }
}

const AUDIO_ICON_TITLE_BY_LOCALE: Record<Locale, string> = {
  en: 'Has audio',
  pt: 'Tem áudio',
  es: 'Tiene audio',
  it: 'Ha audio',
  hi: 'ऑडियो है',
  ar: 'يوجد صوت',
};

const CARD_LOCALES = [...SUPPORTED_LOCALES].map((locale) => ({
  locale,
  href: `${FULL_BASE}chants/${chant.slug}/${langQuery(locale)}`,
  description: getDescriptionByLocale(chant.description, locale),
  audioTitle: AUDIO_ICON_TITLE_BY_LOCALE[locale],
}));
---

<div class="sc-card chant-card block rounded-lg border transition hover:shadow-sm" style="background-color: var(--sc-bg-elevated); border-color: var(--sc-border); --tw-shadow-color: var(--sc-border);">
  {CARD_LOCALES.map(({ locale, href, description, audioTitle }) => (
    <a href={href} class={`locale-${locale} block p-6`}>
      <p class="text-sm uppercase tracking-wider" style="color: var(--sc-text-muted)">{chant.tradition}</p>
      <div class="chant-card__title-row flex items-center gap-2 mt-1 flex-wrap">
        <h2 class="sc-card-title font-serif text-xl min-w-0 flex-1" style="color: var(--sc-text)">{chant.title}</h2>
        {chant.audio && chant.interpreter && <span class="text-sm flex-shrink-0" style="color: var(--sc-text-muted)">{chant.interpreter}</span>}
        {chant.audio && (
          <span class="chant-card__audio-icon flex-shrink-0" aria-hidden="true" title={audioTitle}>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--sc-text-muted)"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="2.5"/><circle cx="18" cy="16" r="2.5"/></svg>
          </span>
        )}
      </div>
      <p class="text-sm mt-2 line-clamp-2" style="color: var(--sc-text-muted)">{description}</p>
      {chant.tags && chant.tags.length > 0 && (
        <ul class="flex flex-wrap gap-1 mt-3">
          {chant.tags.slice(0, 3).map((tag) => (
            <li><span class="text-xs" style="color: var(--sc-text-subtle)">#{tag}</span></li>
          ))}
        </ul>
      )}
    </a>
  ))}
</div>
