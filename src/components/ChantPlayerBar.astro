---
interface Props {
  audioUrl: string;
  title: string;
  hasSync: boolean;
  syncLabelEn: string;
  syncLabelPt: string;
  syncOnEn: string;
  syncOffEn: string;
  syncOnPt: string;
  syncOffPt: string;
  bandcampUrl?: string;
  bandcampEmbedSrc?: string;
  bandcampTooltipEn?: string;
  bandcampTooltipPt?: string;
}

const { audioUrl, title, hasSync, syncLabelEn, syncLabelPt, syncOnEn, syncOffEn, syncOnPt, syncOffPt, bandcampUrl, bandcampEmbedSrc, bandcampTooltipEn = 'Listen on Bandcamp', bandcampTooltipPt = 'Ouvir no Bandcamp' } = Astro.props;
const audioId = 'chant-audio';
const seekId = audioId + '-seek';
const playId = audioId + '-play';
---

<div
  class="chant-player-bar chant-player-bar--fixed flex items-center gap-3 px-page-x py-2 flex-wrap md:flex-nowrap"
  style="background-color: var(--sc-bg-elevated);"
  role="region"
  aria-label={title + ' — player'}
>
  <audio id={audioId} preload="metadata" class="hidden" aria-hidden="true">
    <source src={audioUrl} type="audio/mpeg" />
    <source src={audioUrl} type="audio/ogg" />
  </audio>
  <div class="flex items-center gap-2 flex-1 min-w-0 w-full md:w-auto">
  <button
    type="button"
    id={playId}
    class="chant-audio-play flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center border cursor-pointer transition-colors"
    style="background-color: var(--sc-bg); border-color: var(--sc-border); color: var(--sc-text);"
    aria-label={title + ' — play'}
  >
    <span aria-hidden="true">▶</span>
  </button>
  <span id="chant-time-current" class="chant-time text-xs tabular-nums min-w-[2.5rem]" style="color: var(--sc-text-muted)">0:00</span>
  <label class="flex-1 min-w-0 flex items-center" for={seekId}>
    <input
      type="range"
      id={seekId}
      name="chant-audio-seek"
      min="0"
      max="100"
      value="0"
      class="chant-audio-seek w-full h-1.5 rounded-full cursor-pointer accent-current"
      style="color: var(--sc-text-muted);"
      aria-label="Position"
    />
  </label>
  <span id="chant-time-remaining" class="chant-time text-xs tabular-nums min-w-[2.5rem]" style="color: var(--sc-text-muted)">−0:00</span>
  {hasSync && (
    <div class="flex items-center gap-2 flex-shrink-0">
      <span class="text-xs uppercase tracking-wider" style="color: var(--sc-text-subtle)">
        <span class="locale-en">{syncLabelEn}</span>
        <span class="locale-pt">{syncLabelPt}</span>
      </span>
      <button
        type="button"
        id="chant-sync-toggle"
        class="chant-sync-switch chant-sync-switch--track w-9 relative inline-flex h-5 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--sc-bg-elevated)]"
        style="--ring-color: var(--sc-accent);"
        aria-pressed="true"
        role="switch"
        data-sync-on
        data-sync-on-en={syncOnEn}
        data-sync-off-en={syncOffEn}
        data-sync-on-pt={syncOnPt}
        data-sync-off-pt={syncOffPt}
      >
        <span class="chant-sync-switch-thumb pointer-events-none inline-block h-4 w-4 rounded-full shadow-sm transition-transform duration-200 ease-out"></span>
        <span class="sr-only locale-en"><span id="chant-sync-toggle-state">{syncOnEn}</span></span>
        <span class="sr-only locale-pt"><span id="chant-sync-toggle-state-pt">{syncOnPt}</span></span>
      </button>
    </div>
  )}
  </div>
  {bandcampUrl && (
    <div class="flex items-center gap-2 flex-shrink-0 border-l pl-3" style="border-color: var(--sc-border);">
      <a href={bandcampUrl} target="_blank" rel="noopener noreferrer" class="chant-bar-bandcamp locale-en flex items-center justify-center w-8 h-8 rounded-full transition-opacity hover:opacity-80" title={bandcampTooltipEn} aria-label={bandcampTooltipEn}>
        <svg class="chant-bar-bandcamp-icon chant-bar-bandcamp-icon--shape" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
          <circle cx="12" cy="12" r="12" fill="#000"/>
          <polygon points="5,9 19,9 17,15 3,15" fill="#fff"/>
        </svg>
      </a>
      <a href={bandcampUrl} target="_blank" rel="noopener noreferrer" class="chant-bar-bandcamp locale-pt flex items-center justify-center w-8 h-8 rounded-full transition-opacity hover:opacity-80" title={bandcampTooltipPt} aria-label={bandcampTooltipPt}>
        <svg class="chant-bar-bandcamp-icon chant-bar-bandcamp-icon--shape" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
          <circle cx="12" cy="12" r="12" fill="#000"/>
          <polygon points="5,9 19,9 17,15 3,15" fill="#fff"/>
        </svg>
      </a>
    </div>
  )}
</div>
<script is:inline define:vars={{ audioId, seekId, playId }}>
  (function() {
    var audio = document.getElementById(audioId);
    var seek = document.getElementById(seekId);
    var playBtn = document.getElementById(playId);
    var timeCurrent = document.getElementById('chant-time-current');
    var timeRemaining = document.getElementById('chant-time-remaining');
    if (!audio || !seek || !playBtn) return;

    function fmt(sec) {
      if (!Number.isFinite(sec) || sec < 0) return '0:00';
      var m = Math.floor(sec / 60);
      var s = Math.floor(sec % 60);
      return m + ':' + (s < 10 ? '0' : '') + s;
    }
    function updateTime() {
      var cur = audio.currentTime;
      var dur = audio.duration;
      if (timeCurrent) timeCurrent.textContent = fmt(cur);
      if (timeRemaining) timeRemaining.textContent = Number.isFinite(dur) && dur > 0 ? '−' + fmt(dur - cur) : '−0:00';
    }
    function setPlaying(playing) {
      playBtn.innerHTML = playing ? '<span aria-hidden="true">⏸</span>' : '<span aria-hidden="true">▶</span>';
      playBtn.setAttribute('aria-label', audio.getAttribute('aria-label') + (playing ? ' — pause' : ' — play'));
    }
    function updateSeek() {
      var pct = audio.duration ? (100 * audio.currentTime / audio.duration) : 0;
      seek.value = String(pct);
      updateTime();
    }
    audio.addEventListener('loadedmetadata', function() { updateSeek(); updateTime(); });
    audio.addEventListener('timeupdate', updateSeek);
    audio.addEventListener('play', function() { setPlaying(true); });
    audio.addEventListener('pause', function() { setPlaying(false); });
    audio.addEventListener('ended', function() { setPlaying(false); updateSeek(); });
    playBtn.addEventListener('click', function() {
      if (audio.paused) audio.play(); else audio.pause();
    });
    seek.addEventListener('input', function() {
      var t = (audio.duration || 0) * (Number(seek.value) / 100);
      audio.currentTime = t;
      updateTime();
    });
    setPlaying(false);
    updateTime();
  })();
</script>
