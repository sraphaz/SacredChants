---
import type { Chant } from '../content/schemas/chant';

interface Props {
  chant: Chant;
}

const { chant } = Astro.props;
---

<header class="chant-header text-center mb-section max-w-[var(--sc-measure-reading)] mx-auto">
  <p class="chant-header__meta text-sc-sm uppercase tracking-label text-stone-500 mb-2" aria-hidden="true">
    {chant.tradition}
    {chant.origin ? ` · ${chant.origin}` : ''}
  </p>
  <h1 class="chant-header__title sc-heading font-serif text-sc-4xl md:text-sc-5xl mb-4">
    {chant.title}
  </h1>
  {chant.language && (
    <p class="chant-header__lang text-stone-600 text-sc-sm">
      {chant.language}
      {chant.script ? ` (${chant.script})` : ''}
    </p>
  )}
  {(chant.description?.en || chant.description?.pt) && (
    <div class="chant-header__desc mt-6 max-w-[var(--sc-measure-narrow)] mx-auto" style="line-height: var(--sc-leading-relaxed);">
      {chant.description.en && (
        <p class="locale-en text-stone-600 text-sc-base" style="color: var(--sc-text-muted);">
          {chant.description.en}
        </p>
      )}
      {chant.description.pt && (
        <p class="locale-pt text-stone-600 text-sc-base" style="color: var(--sc-text-muted);">
          {chant.description.pt}
        </p>
      )}
    </div>
  )}
  {chant.tags && chant.tags.length > 0 && (
    <ul class="chant-header__tags flex flex-wrap justify-center gap-2 mt-6" aria-label="Tags">
      {chant.tags.map((tag) => (
        <li>
          <span class="text-sc-xs px-2 py-1 rounded bg-stone-100 text-stone-600">{tag}</span>
        </li>
      ))}
    </ul>
  )}
</header>
