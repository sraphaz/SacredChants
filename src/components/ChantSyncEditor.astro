---
import { SUPPORTED_LOCALES, type Locale } from '../i18n/strings';

interface SyncEditorLabels {
  editSync: string;
  editOn: string;
  editOff: string;
  line: string;
  nudgeHint: string;
  editHint: string;
  draftSaved: string;
  draftRestored: string;
  copyJson: string;
  downloadJson: string;
  reset: string;
  openPr: string;
  copied: string;
  copyFailed: string;
  downloaded: string;
  resetDone: string;
  nudged: string;
  noChanges: string;
  prSubmitting: string;
  prOk: string;
  prFailed: string;
  prAuth: string;
  prUnavailable: string;
  hotkeys: string;
}

interface Props {
  slug: string;
  labelsByLocale: Record<Locale, SyncEditorLabels>;
  apiOrigin?: string;
}

const { slug, labelsByLocale, apiOrigin = '' } = Astro.props;
const locales = [...SUPPORTED_LOCALES] as Locale[];
const en = labelsByLocale.en;
---

<aside
  id="chant-sync-editor"
  class="chant-sync-rail"
  hidden
  data-slug={slug}
  data-api-origin={apiOrigin}
  aria-label={en.editSync}
>
  <!-- Idle: thin edge; hover/focus/touch expands the pad -->
  <div class="chant-sync-rail__edge" aria-hidden="true"></div>

  <div
    id="chant-sync-editor-pad"
    class="chant-sync-rail__pad"
    role="group"
    aria-label={en.nudgeHint}
    tabindex="0"
  >
    <div class="chant-sync-rail__meta">
      <span id="chant-sync-editor-line" class="chant-sync-rail__line"></span>
      <span id="chant-sync-editor-start" class="chant-sync-rail__start"></span>
      <span id="chant-sync-editor-dirty" class="chant-sync-rail__dot" hidden title={en.draftSaved} aria-label={en.draftSaved}>·</span>
    </div>

    <p class="chant-sync-rail__hint">
      {locales.map((loc) => (
        <span class={`locale-${loc}`}>{labelsByLocale[loc].hotkeys}</span>
      ))}
    </p>

    <div class="chant-sync-rail__micro">
      <button type="button" class="chant-sync-rail__tick" data-nudge="-0.1" title="-0.1s" aria-label="-0.1s">−</button>
      <button type="button" class="chant-sync-rail__tick" data-nudge="0.1" title="+0.1s" aria-label="+0.1s">+</button>
    </div>

    <div class="chant-sync-rail__menu-wrap">
      <button
        type="button"
        id="chant-sync-rail-menu-btn"
        class="chant-sync-rail__menu-btn"
        aria-expanded="false"
        aria-controls="chant-sync-rail-menu"
        aria-haspopup="true"
      >
        ···
      </button>
      <div id="chant-sync-rail-menu" class="chant-sync-rail__menu" hidden role="menu">
        <button type="button" role="menuitem" id="chant-sync-export-copy" class="chant-sync-rail__menu-item">
          {locales.map((loc) => (
            <span class={`locale-${loc}`}>{labelsByLocale[loc].copyJson}</span>
          ))}
        </button>
        <button type="button" role="menuitem" id="chant-sync-export-download" class="chant-sync-rail__menu-item">
          {locales.map((loc) => (
            <span class={`locale-${loc}`}>{labelsByLocale[loc].downloadJson}</span>
          ))}
        </button>
        <button type="button" role="menuitem" id="chant-sync-editor-reset" class="chant-sync-rail__menu-item">
          {locales.map((loc) => (
            <span class={`locale-${loc}`}>{labelsByLocale[loc].reset}</span>
          ))}
        </button>
        <button type="button" role="menuitem" id="chant-sync-export-pr" class="chant-sync-rail__menu-item">
          {locales.map((loc) => (
            <span class={`locale-${loc}`}>{labelsByLocale[loc].openPr}</span>
          ))}
        </button>
      </div>
    </div>

    <p id="chant-sync-editor-status" class="chant-sync-rail__status" hidden role="status"></p>
  </div>
</aside>
