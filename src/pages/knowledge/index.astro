---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import { ui, type Locale } from '../../i18n/strings';

const locale = (Astro.url.searchParams.get('lang') === 'pt' ? 'pt' : 'en') as Locale;
const t = ui[locale];
const tEn = ui.en;
const tPt = ui.pt;
const BASE = import.meta.env.BASE_URL || '/';
const BASE_SLASH = BASE.endsWith('/') ? BASE : BASE + '/';
const langQuery = locale === 'pt' ? '?lang=pt' : '';
const FULL_BASE = Astro.url.origin + (BASE_SLASH.startsWith('/') ? BASE_SLASH : '/' + BASE_SLASH);

/** Single nav item for a knowledge page */
function item(slug: string, titleEn: string, titlePt: string) {
  return { slug, titleEn, titlePt };
}

/** Sections: label key (in tEn/tPt.knowledge) + items. Order defines page hierarchy. */
const sections = [
  {
    labelKey: 'sectionStartHere' as const,
    items: [item('sound-and-humanity', tEn.knowledge.soundAndHumanity, tPt.knowledge.soundAndHumanity)],
  },
  {
    labelKey: 'sectionFirstPillar' as const,
    items: [item('nada-yoga', tEn.knowledge.nadaYoga, tPt.knowledge.nadaYoga)],
  },
  {
    labelKey: 'sectionConcepts' as const,
    items: [
      item('vibration-mind', tEn.knowledge.vibrationMind, tPt.knowledge.vibrationMind),
      item('elements-and-sound', tEn.knowledge.elementsAndSound, tPt.knowledge.elementsAndSound),
      item('sound-attributes', tEn.knowledge.soundAttributes, tPt.knowledge.soundAttributes),
    ],
  },
  {
    labelKey: 'sectionGoDeeper' as const,
    items: [item('balance-and-healing', tEn.knowledge.balanceAndHealing, tPt.knowledge.balanceAndHealing)],
  },
  {
    labelKey: 'sectionReferences' as const,
    items: [item('references', tEn.knowledge.references, tPt.knowledge.references)],
  },
];
---

<BaseLayout
  title={t.knowledge.title}
  description={t.knowledge.description}
  locale={locale}
>
  <PageShell>
    <h1 class="font-serif text-sc-3xl sc-heading mb-page-heading">
      {t.knowledge.title}
    </h1>
    <p class="mb-page-content" style="color: var(--sc-text-muted)">
      {t.knowledge.description}
    </p>
    <p class="mb-10 max-w-[var(--sc-measure-reading)]" style="color: var(--sc-text-muted)">
      <span class="locale-en">{tEn.knowledge.intro}</span>
      <span class="locale-pt">{tPt.knowledge.intro}</span>
    </p>

    <nav class="flex flex-col max-w-2xl" style="gap: var(--sc-space-section-gap)" aria-label="Knowledge sections">
      {sections.map((section) => (
        <section class="flex flex-col gap-3" aria-labelledby={`knowledge-heading-${section.labelKey}`}>
          <h2
            id={`knowledge-heading-${section.labelKey}`}
            class="text-xs font-medium tracking-wider uppercase"
            style="color: var(--sc-text-subtle)"
          >
            <span class="locale-en">{tEn.knowledge[section.labelKey]}</span>
            <span class="locale-pt">{tPt.knowledge[section.labelKey]}</span>
          </h2>
          <ul class="flex flex-col gap-2 list-none p-0 m-0">
            {section.items.map((item) => {
              const href = `${FULL_BASE}knowledge/${item.slug}/${langQuery}`;
              const isFirstPillar = section.labelKey === 'sectionFirstPillar';
              return (
                <li>
                  <a
                    href={href}
                    class:list={[
                      'block w-full text-left rounded-xl transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--sc-accent)]',
                      isFirstPillar
                        ? 'sc-btn-primary py-3 px-5 font-medium'
                        : 'py-3 px-4 border border-[var(--sc-border)] bg-[var(--sc-bg-elevated)] hover:border-[var(--sc-text-subtle)] hover:bg-[var(--sc-accent-soft)]',
                    ]}
                    style={!isFirstPillar ? { color: 'var(--sc-text)' } : undefined}
                  >
                    <span class="locale-en">{item.titleEn}</span>
                    <span class="locale-pt">{item.titlePt}</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      ))}
    </nav>
  </PageShell>
</BaseLayout>
