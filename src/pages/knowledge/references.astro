---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import KnowledgePageHeader from '../../components/KnowledgePageHeader.astro';
import SaveOfflineToggle from '../../components/SaveOfflineToggle.astro';
import { ui, getLocaleFromUrl, langQuery } from '../../i18n/strings';
import { getFullBase } from '../../utils/base';
import { buildCanonicalPageUrl } from '../../utils/offline-page-url';

const locale = getLocaleFromUrl(Astro.url.searchParams);
const t = ui[locale];
const tEn = ui.en;
const tPt = ui.pt;
const tEs = ui.es;
const tIt = ui.it;
const tHi = ui.hi;
const localeQuery = langQuery(locale);
const FULL_BASE = getFullBase(Astro.url);
const pageUrlForOffline = buildCanonicalPageUrl(
  Astro.url.origin,
  Astro.url.pathname,
  Astro.url.search
);
---

<BaseLayout
  title={t.knowledge.references}
  description="References and further reading for Nada Yoga and the five elements."
  locale={locale}
>
  <PageShell>
    <KnowledgePageHeader
      backHref={`${FULL_BASE}knowledge/${localeQuery}`}
      titleByLocale={{
        en: tEn.knowledge.references,
        pt: tPt.knowledge.references,
        es: tEs.knowledge.references,
        it: tIt.knowledge.references,
        hi: tHi.knowledge.references,
      }}
      backLabelByLocale={{
        en: tEn.knowledge.backToKnowledge,
        pt: tPt.knowledge.backToKnowledge,
        es: tEs.knowledge.backToKnowledge,
        it: tIt.knowledge.backToKnowledge,
        hi: tHi.knowledge.backToKnowledge,
      }}
    />

    <SaveOfflineToggle
      mode="toolbar"
      class="mb-8"
      storageSlug="__knowledge-references__"
      pageUrl={pageUrlForOffline}
      toolbarAriaLabel={t.settings.offlineTitle}
    />

    <div class="prose prose-neutral max-w-[var(--sc-measure-reading)] space-y-6" style="color: var(--sc-text-muted)">
      <section>
        <h2 class="font-serif text-xl sc-heading mb-2" style="color: var(--sc-text)">
          <span class="locale-en">Classical texts</span>
          <span class="locale-pt">Textos clássicos</span>
          <span class="locale-es">Textos clásicos</span>
          <span class="locale-it">Testi classici</span>
          <span class="locale-hi">शास्त्रीय ग्रंथ</span>
        </h2>
        <ul class="list-disc pl-6 space-y-2">
          <li class="locale-en"><strong>Hatha Yoga Pradīpikā</strong> (Svātmārāma) — Nada Yoga as a central meditation technique to still the mind.</li>
          <li class="locale-pt"><strong>Hatha Yoga Pradīpikā</strong> (Svātmārāma) — Nada Yoga como técnica central de meditação para aquietar a mente.</li>
          <li class="locale-en"><strong>Nada Bindu Upanishad</strong> — Classical text on inner sound and the unstruck sound (<em>anāhata</em>).</li>
          <li class="locale-pt"><strong>Nada Bindu Upanishad</strong> — Texto clássico sobre o som interior e o som não percutido (<em>anāhata</em>).</li>
          <li class="locale-en"><strong>Panchadasi</strong> (e.g. Ch. 2, Swami Krishnananda) — Discrimination of the elements (Pancha Mahābhūta).</li>
          <li class="locale-pt"><strong>Panchadasi</strong> (ex. Cap. 2, Swami Krishnananda) — Discriminação dos elementos (Pancha Mahābhūta).</li>
          <li class="locale-es"><strong>Hatha Yoga Pradīpikā</strong> (Svātmārāma) — Nada Yoga como técnica central de meditación para aquietar la mente.</li>
          <li class="locale-es"><strong>Nada Bindu Upanishad</strong> — Texto clásico sobre el sonido interior y el sonido no golpeado (<em>anāhata</em>).</li>
          <li class="locale-es"><strong>Panchadasi</strong> (cap. 2, Swami Krishnananda) — Discriminación de los elementos (Pancha Mahābhūta).</li>
          <li class="locale-it"><strong>Hatha Yoga Pradīpikā</strong> (Svātmārāma) — Nada Yoga come tecnica centrale di meditazione per quietare la mente.</li>
          <li class="locale-it"><strong>Nada Bindu Upanishad</strong> — Testo classico sul suono interiore e il suono non percosso (<em>anāhata</em>).</li>
          <li class="locale-it"><strong>Panchadasi</strong> (cap. 2, Swami Krishnananda) — Discriminazione degli elementi (Pancha Mahābhūta).</li>
          <li class="locale-hi"><strong>हठयोगप्रदीपिका</strong> (स्वात्माराम) — मन को शांत करने हेतु नाद योग।</li>
          <li class="locale-hi"><strong>नादबिंदु उपनिषद्</strong> — अंतर्गत ध्वनि व अनाहत नाद।</li>
          <li class="locale-hi"><strong>पंचदशी</strong> (अध्याय 2, स्वामी कृष्णानंद) — पंच महाभूतों का विवेक।</li>
        </ul>
      </section>

      <section>
        <h2 class="font-serif text-xl sc-heading mb-2" style="color: var(--sc-text)">
          <span class="locale-en">Online and modern sources</span>
          <span class="locale-pt">Fontes online e modernas</span>
          <span class="locale-es">Fuentes en línea y modernas</span>
          <span class="locale-it">Fonti online e moderne</span>
          <span class="locale-hi">ऑनलाइन व आधुनिक स्रोत</span>
        </h2>
        <ul class="list-disc pl-6 space-y-2">
          <li class="locale-en"><strong>Wikipedia:</strong> “<a href="https://en.wikipedia.org/wiki/N%C4%81da_yoga" target="_blank" rel="noopener noreferrer" class="underline" style="color: var(--sc-accent)">Nāda yoga</a>”, “<a href="https://en.wikipedia.org/wiki/Pancha_Bhuta" target="_blank" rel="noopener noreferrer" class="underline" style="color: var(--sc-accent)">Pancha Bhuta</a>”, “<a href="https://en.wikipedia.org/wiki/Anahata_(sound)" target="_blank" rel="noopener noreferrer" class="underline" style="color: var(--sc-accent)">Anahata (sound)</a>”.</li>
          <li class="locale-pt"><strong>Wikipedia:</strong> “Nāda yoga”, “Pancha Bhuta”, “Anahata (sound)”.</li>
          <li class="locale-en"><strong>Dharmawiki</strong> — “<a href="https://dharmawiki.org/index.php/Panchamahabhutas" target="_blank" rel="noopener noreferrer" class="underline" style="color: var(--sc-accent)">Panchamahabhutas</a>” (five elements, qualities, body and cosmos).</li>
          <li class="locale-pt"><strong>Dharmawiki</strong> — “Panchamahabhutas” (cinco elementos, qualidades, corpo e cosmos).</li>
          <li class="locale-en"><strong>The Yoga Institute</strong> — “Pancha Bhoota” (five elements in yoga and health).</li>
          <li class="locale-pt"><strong>The Yoga Institute</strong> — “Pancha Bhoota” (cinco elementos no yoga e na saúde).</li>
          <li class="locale-en"><strong>Nada Yoga Society</strong>, <strong>Yoga Basics</strong> — Introductions to Nada Yoga and the yoga of sound.</li>
          <li class="locale-pt"><strong>Nada Yoga Society</strong>, <strong>Yoga Basics</strong> — Introduções ao Nada Yoga e ao yoga do som.</li>
          <li class="locale-es"><strong>Wikipedia:</strong> "Nāda yoga", "Pancha Bhuta", "Anahata (sound)".</li>
          <li class="locale-es"><strong>Dharmawiki</strong> — "Panchamahabhutas" (cinco elementos, cualidades, cuerpo y cosmos).</li>
          <li class="locale-es"><strong>The Yoga Institute</strong> — "Pancha Bhoota" (cinco elementos en yoga y salud).</li>
          <li class="locale-es"><strong>Nada Yoga Society</strong>, <strong>Yoga Basics</strong> — Introducciones al Nada Yoga y al yoga del sonido.</li>
          <li class="locale-it"><strong>Wikipedia:</strong> "Nāda yoga", "Pancha Bhuta", "Anahata (sound)".</li>
          <li class="locale-it"><strong>Dharmawiki</strong> — "Panchamahabhutas" (cinque elementi, qualità, corpo e cosmo).</li>
          <li class="locale-it"><strong>The Yoga Institute</strong> — "Pancha Bhoota" (cinque elementi nello yoga e nella salute).</li>
          <li class="locale-it"><strong>Nada Yoga Society</strong>, <strong>Yoga Basics</strong> — Introduzioni al Nada Yoga e allo yoga del suono.</li>
          <li class="locale-hi"><strong>Wikipedia:</strong> «<a href="https://en.wikipedia.org/wiki/N%C4%81da_yoga" target="_blank" rel="noopener noreferrer" class="underline" style="color: var(--sc-accent)">नाद योग</a>», «<a href="https://en.wikipedia.org/wiki/Pancha_Bhuta" target="_blank" rel="noopener noreferrer" class="underline" style="color: var(--sc-accent)">पंच भूत</a>», «<a href="https://en.wikipedia.org/wiki/Anahata_(sound)" target="_blank" rel="noopener noreferrer" class="underline" style="color: var(--sc-accent)">अनाहत (ध्वनि)</a>»।</li>
          <li class="locale-hi"><strong>Dharmawiki</strong> — पंचमहाभूत (पाँच तत्व, गुण, शरीर व ब्रह्मांड)।</li>
          <li class="locale-hi"><strong>Nada Yoga Society</strong>, <strong>Yoga Basics</strong> — नाद योग व ध्वनि-योग का परिचय।</li>
        </ul>
      </section>

      <p class="locale-en text-sm mt-8" style="color: var(--sc-text-subtle)">
        This list is offered for further study. Sacred Chants does not endorse any single tradition or interpretation; the aim is to preserve and share knowledge as part of humanity’s heritage.
      </p>
      <p class="locale-pt text-sm mt-8" style="color: var(--sc-text-subtle)">
        Esta lista é oferecida para estudo adicional. O Sacred Chants não endossa qualquer tradição ou interpretação única; o objectivo é preservar e partilhar conhecimento como parte do patrimônio da humanidade.
      </p>
      <p class="locale-es text-sm mt-8" style="color: var(--sc-text-subtle)">
        Esta lista se ofrece para estudio adicional. Sacred Chants no respalda ninguna tradición o interpretación única; el objetivo es preservar y compartir conocimiento como parte del patrimonio de la humanidad.
      </p>
      <p class="locale-it text-sm mt-8" style="color: var(--sc-text-subtle)">
        Questa lista è offerta per ulteriore studio. Sacred Chants non sostiene alcuna tradizione o interpretazione unica; l'obiettivo è preservare e condividere la conoscenza come parte del patrimonio dell'umanità.
      </p>
      <p class="locale-hi text-sm mt-8" style="color: var(--sc-text-subtle)">
        यह सूची आगे पढ़ने के लिए है। Sacred Chants किसी एक परंपरा या व्याख्या का समर्थन नहीं करता; उद्देश्य मानवता की विरासत के रूप में ज्ञान संरक्षित व साझा करना है।
      </p>
    </div>
  </PageShell>
</BaseLayout>
