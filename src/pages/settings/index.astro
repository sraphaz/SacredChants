---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import SaveOfflineToggle from '../../components/SaveOfflineToggle.astro';
import { ui, getLocaleFromUrl, SUPPORTED_LOCALES } from '../../i18n/strings';
import { getFullBase } from '../../utils/base';
import { buildCanonicalPageUrl } from '../../utils/offline-page-url';

const locale = getLocaleFromUrl(Astro.url.searchParams);
const FULL_BASE = getFullBase(Astro.url);
const tEn = ui.en;
const tPt = ui.pt;
const tEs = ui.es;
const tIt = ui.it;
const tHi = ui.hi;
const tAr = ui.ar;
const titleMap = {
  en: tEn.settings.title,
  pt: tPt.settings.title,
  es: tEs.settings.title,
  it: tIt.settings.title,
  hi: tHi.settings.title,
  ar: tAr.settings.title,
};
const descMap = {
  en: tEn.settings.description,
  pt: tPt.settings.description,
  es: tEs.settings.description,
  it: tIt.settings.description,
  hi: tHi.settings.description,
  ar: tAr.settings.description,
};
const supportedLocalesJson = JSON.stringify([...SUPPORTED_LOCALES]);
const pageUrlForOffline = buildCanonicalPageUrl(
  Astro.url.origin,
  Astro.url.pathname,
  Astro.url.search
);
---

<BaseLayout
  title={titleMap[locale]}
  description={descMap[locale]}
  locale={locale}
>
  <PageShell>
    <h1 class="font-serif text-sc-3xl md:text-sc-4xl sc-heading mb-page-heading">
      <span class="locale-en">{tEn.settings.title}</span>
      <span class="locale-pt">{tPt.settings.title}</span>
      <span class="locale-es">{tEs.settings.title}</span>
      <span class="locale-it">{tIt.settings.title}</span>
      <span class="locale-hi">{tHi.settings.title}</span>
      <span class="locale-ar" dir="rtl">{tAr.settings.title}</span>
    </h1>
    <p class="mb-page-content text-sm" style="color: var(--sc-text-muted)">
      <span class="locale-en">{tEn.settings.description}</span>
      <span class="locale-pt">{tPt.settings.description}</span>
      <span class="locale-es">{tEs.settings.description}</span>
      <span class="locale-it">{tIt.settings.description}</span>
      <span class="locale-hi">{tHi.settings.description}</span>
      <span class="locale-ar" dir="rtl">{tAr.settings.description}</span>
    </p>

    <form id="settings-form" class="settings-form space-y-10" autocomplete="off" aria-label={titleMap[locale]}>
