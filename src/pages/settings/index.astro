          <span class="locale-es">{tEs.settings.theme}</span>
          <span class="locale-it">{tIt.settings.theme}</span>
          <span class="locale-hi">{tHi.settings.theme}</span>
          <span class="locale-ar" dir="rtl">{tAr.settings.theme}</span>
        </label>
        <div class="settings-options">
          <label class="settings-option" for="settings-theme-dark">
            <input type="radio" id="settings-theme-dark" name="theme" value="dark" class="settings-option-input" />
            <span class="settings-option-text"><span class="locale-en">{tEn.settings.themeDark}</span>
              <span class="locale-pt">{tPt.settings.themeDark}</span>
              <span class="locale-es">{tEs.settings.themeDark}</span>
              <span class="locale-it">{tIt.settings.themeDark}</span>
