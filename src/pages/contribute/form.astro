---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import SaveOfflineToggle from '../../components/SaveOfflineToggle.astro';
import { ui, getLocaleFromUrl, langQuery } from '../../i18n/strings';
import { buildCanonicalPageUrl } from '../../utils/offline-page-url';

const locale = getLocaleFromUrl(Astro.url.searchParams);
const t = ui[locale];
const apiOrigin = import.meta.env.PUBLIC_CONTRIBUTE_API_ORIGIN ?? '';
const contributeAppUrl = (import.meta.env.PUBLIC_CONTRIBUTE_APP_URL as string)?.trim() ?? '';
const useAppSubdomain = contributeAppUrl.length > 0;
const contributeAppBase = useAppSubdomain ? `${contributeAppUrl.replace(/\/$/, '')}/contribute/` : '';
const localeQuery = langQuery(locale);
const contributeAppContributeUrl = useAppSubdomain ? contributeAppBase + 'form/' + (localeQuery || '') : '';
const returnToForm = '/contribute/form/' + (localeQuery || '');
const f = t.contribute.form;
const pageUrlForOffline = buildCanonicalPageUrl(
  Astro.site,
  Astro.url.pathname,
  Astro.url.search
);
---

<BaseLayout
  title={t.contribute.newContribution + ' — ' + t.contribute.title}
  description={t.contribute.description}
  locale={locale}
>
  <PageShell>
    <h1 class="font-serif text-sc-3xl sc-heading mb-page-heading">
      {t.contribute.newContribution}
    </h1>

    <SaveOfflineToggle
      mode="toolbar"
      class="mb-8"
      storageSlug="__contribute-form__"
      pageUrl={pageUrlForOffline}
    />

    <div id="contribute-form-root" data-api-origin={apiOrigin} data-contribute-app-url={useAppSubdomain ? contributeAppContributeUrl : undefined}>
      {useAppSubdomain ? (
        <div class="mb-6">
          <p style="color: var(--sc-text-muted)">{t.contribute.useContributeApp}</p>
          <a href={contributeAppContributeUrl} class="sc-btn-primary inline-flex mt-2 px-5 py-2.5 rounded-lg">
            {t.contribute.openContributeApp}
          </a>
        </div>
      ) : (
      <>
        <div id="form-login-required" class="mb-6">
          <p style="color: var(--sc-text-muted)">{t.contribute.loginToContribute}</p>
          <a href={`${apiOrigin}/api/auth/github?returnTo=${encodeURIComponent(returnToForm)}`} class="sc-btn-primary inline-flex mt-2 px-5 py-2.5 rounded-lg">
            {t.contribute.signInWithGitHub}
          </a>
        </div>

        <div id="form-wizard" class="contribute-form-one-page hidden">
          <p id="form-error" class="contribute-form-error text-red-600 hidden" role="alert"></p>
          <p id="form-success" class="hidden mb-6" style="color: var(--sc-text-muted)" role="status"></p>

          <div id="drafts-panel" class="contribute-drafts-panel hidden">
            <h3 class="contribute-drafts-title">{f.myDrafts}</h3>
            <p id="drafts-empty" class="contribute-drafts-empty">{f.noDrafts}</p>
            <ul id="drafts-list" class="contribute-drafts-list" aria-label={f.myDrafts}></ul>
          </div>
          <nav class="contribute-form-nav" aria-label={f.formNavAriaLabel}>
            <a href="#form-section-metadata" class="contribute-form-nav-link" data-section="metadata">{f.stepMetadata}</a>
            <span class="contribute-form-nav-sep" aria-hidden="true">·</span>
            <a href="#form-section-verses" class="contribute-form-nav-link" data-section="verses">{f.stepVerses}</a>
            <span class="contribute-form-nav-sep" aria-hidden="true">·</span>
            <a href="#form-section-review" class="contribute-form-nav-link" data-section="review">{f.stepReview}</a>
          </nav>

          <!-- Single page: three sections, each appearing once -->
          <div class="contribute-form-sections">
            <!-- 1. Metadata (once) -->
            <section id="form-section-metadata" class="contribute-form-section" aria-labelledby="section-metadata-heading">
              <span class="contribute-form-section-badge" aria-hidden="true">1</span>
              <h2 id="section-metadata-heading" class="contribute-form-section-title">{f.stepMetadata}</h2>
              <div class="contribute-form-section-inner space-y-3">
                <div>
                  <label for="slug" class="contribute-form-label">{f.slugLabel}</label>
                  <input type="text" id="slug" name="slug" required pattern="[a-z0-9][a-z0-9-]*" placeholder={f.slugPlaceholder} class="contribute-form-input" />
                </div>
                <div>
                  <label for="title" class="contribute-form-label">{f.titleLabel}</label>
                  <input type="text" id="title" name="title" required class="contribute-form-input" />
                </div>
                <div>
                  <label for="tradition" class="contribute-form-label">{f.traditionLabel}</label>
                  <input type="text" id="tradition" name="tradition" required placeholder={f.traditionPlaceholder} class="contribute-form-input" />
                </div>
                <div>
                  <label for="language" class="contribute-form-label">{f.languageLabel}</label>
                  <input type="text" id="language" name="language" required placeholder={f.languagePlaceholder} class="contribute-form-input" />
                </div>
                <div>
                  <label for="content_language" class="contribute-form-label">{f.contentLanguageLabel}</label>
                  <p class="contribute-form-field-hint" id="content_language-hint">{f.contentLanguageHint}</p>
                  <select id="content_language" name="content_language" class="contribute-form-input" aria-describedby="content_language-hint">
                    <option value="other">{f.contentLanguageOther}</option>
                    <option value="pt">{f.contentLanguagePt}</option>
                    <option value="en">{f.contentLanguageEn}</option>
                  </select>
                </div>
                <div id="description_en-wrap">
                  <label for="description_en" class="contribute-form-label">{f.descriptionEnLabel}</label>
                  <textarea id="description_en" name="description_en" rows="2" class="contribute-form-input"></textarea>
                </div>
                <div id="description_pt-wrap">
                  <label for="description_pt" class="contribute-form-label">{f.descriptionPtLabel}</label>
                  <textarea id="description_pt" name="description_pt" rows="2" class="contribute-form-input"></textarea>
                </div>
                <div>
                  <label for="tags" class="contribute-form-label">{f.tagsLabel}</label>
                  <input type="text" id="tags" name="tags" placeholder={f.tagsPlaceholder} class="contribute-form-input" />
                </div>
                <div class="contribute-audio-block">
                  <p class="contribute-audio-block__title" id="audio-block-title">{f.audioSectionTitle}</p>
                  <p class="contribute-form-field-hint contribute-audio-block__hint" id="audio-block-hint">{f.audioSectionHint}</p>
                  <div class="contribute-audio-block__fields space-y-3">
                    <div>
                      <label for="audio_url" class="contribute-form-label">{f.audioUrlLabel}</label>
                      <input type="url" id="audio_url" name="audio_url" placeholder={f.audioUrlPlaceholder} class="contribute-form-input" />
                    </div>
                    <div>
                      <label for="audio_file" class="contribute-form-label">{f.audioUploadLabel}</label>
                      <p class="contribute-form-field-hint">{f.audioUploadHint}</p>
                      <input type="file" id="audio_file" name="audio_file" accept="audio/*" class="contribute-form-input" />
                    </div>
                    <div>
                      <label for="interpreter" class="contribute-form-label">{f.interpreterLabel}</label>
                      <input type="text" id="interpreter" name="interpreter" placeholder={f.interpreterPlaceholder} class="contribute-form-input" />
                    </div>
                  </div>
                </div>
              </div>
            </section>

            <!-- 2. Verses (once: list + add form) -->
            <section id="form-section-verses" class="contribute-form-section" aria-labelledby="section-verses-heading">
              <span class="contribute-form-section-badge" aria-hidden="true">2</span>
              <h2 id="section-verses-heading" class="contribute-form-section-title">{f.stepVerses}</h2>
              <p class="contribute-form-hint">{f.stepVersesHint}</p>
              <ul id="verses-list" class="contribute-verses-list" aria-label={f.stepVerses}></ul>
              <fieldset class="contribute-form-section-inner contribute-verse-fieldset">
                <legend class="contribute-form-legend" id="current-verse-legend">{f.verseLegend} 1</legend>
                <div class="space-y-3">
                  <div id="v_start-wrap" class="hidden" aria-hidden="true">
                    <label for="v_start" class="contribute-form-label">{f.verseStartLabel}</label>
                    <p id="v_start-hint" class="contribute-form-field-hint">{f.verseStartHint}</p>
                    <input type="number" id="v_start" min="0" step="0.1" placeholder={f.verseStartPlaceholder} class="contribute-form-input contribute-form-input-narrow" aria-describedby="v_start-hint" />
                  </div>
                  <div>
                    <label for="v_original" class="contribute-form-label">{f.verseOriginalLabel}</label>
                    <input type="text" id="v_original" class="contribute-form-input contribute-form-input-serif" />
                  </div>
                  <div>
                    <label for="v_transliteration" class="contribute-form-label">{f.verseTransliterationLabel}</label>
                    <p id="v_transliteration-hint" class="contribute-form-field-hint">{f.verseTransliterationHint}</p>
                    <input type="text" id="v_transliteration" class="contribute-form-input" aria-describedby="v_transliteration-hint" />
                  </div>
                  <div id="verse-translation-en-wrap">
                    <label for="v_translation_en" class="contribute-form-label">{f.verseTranslationEnLabel}</label>
                    <p id="verse-translation-en-optional" class="contribute-form-field-hint hidden"></p>
                    <input type="text" id="v_translation_en" class="contribute-form-input" />
                  </div>
                  <div id="verse-translation-pt-wrap">
                    <label for="v_translation_pt" class="contribute-form-label">{f.verseTranslationPtLabel}</label>
                    <p id="verse-translation-pt-optional" class="contribute-form-field-hint hidden"></p>
                    <input type="text" id="v_translation_pt" class="contribute-form-input" />
                  </div>
                  <button type="button" id="btn-add-verse" class="sc-btn-primary px-5 py-2.5 rounded-lg">{f.addVerse}</button>
                </div>
              </fieldset>
            </section>

            <!-- 3. Review (once, live preview) -->
            <section id="form-section-review" class="contribute-form-section contribute-form-section-review" aria-labelledby="section-review-heading">
              <span class="contribute-form-section-badge" aria-hidden="true">3</span>
              <h2 id="section-review-heading" class="contribute-form-section-title">{f.stepReview}</h2>
              <p class="contribute-form-hint">{f.reviewIntro}</p>
              <p id="review-preview-label" class="contribute-review-preview-label">{f.reviewPreviewLabel}</p>
              <div id="review-preview" class="contribute-review-preview" aria-live="polite"></div>
              <div class="contribute-form-actions">
                <a href={locale === 'pt' ? '/contribute/?lang=pt' : '/contribute/'} class="contribute-form-btn-secondary">{f.cancel}</a>
                <button type="button" id="btn-save-draft" class="contribute-form-btn-secondary">{f.saveDraft}</button>
                <button type="button" id="btn-submit-pr" class="sc-btn-primary px-5 py-2.5 rounded-lg">{f.createPR}</button>
              </div>
            </section>
          </div>
        </div>
      </>
      )}
    </div>
  </PageShell>
</BaseLayout>

<style>
  .contribute-form-one-page { max-width: 36rem; scroll-margin-top: 1rem; }
  .contribute-form-error { margin-bottom: 1rem; }
  .contribute-form-nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem 0.5rem;
    margin-bottom: 1.25rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--sc-border);
  }
  .contribute-form-nav-link {
    font-size: 0.875rem;
    color: var(--sc-text-muted);
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    transition: color 0.2s ease, background-color 0.2s ease;
  }
  .contribute-form-nav-link:hover { color: var(--sc-text); background: var(--sc-border); }
  .contribute-form-nav-link.is-current { color: var(--sc-accent); font-weight: 500; }
  .contribute-form-nav-sep { color: var(--sc-text-muted); font-weight: 300; user-select: none; }
  .contribute-drafts-panel {
    margin-bottom: 1rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--sc-border);
    border-radius: 0.5rem;
    background: var(--sc-bg);
    color: var(--sc-text-muted);
  }
  .contribute-drafts-panel.hidden { display: none; }
  .contribute-drafts-title { font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.03em; margin: 0 0 0.5rem 0; color: var(--sc-text-muted); }
  .contribute-drafts-empty { font-size: 0.8125rem; margin: 0; }
  .contribute-drafts-list { list-style: none; padding: 0; margin: 0; font-size: 0.875rem; }
  .contribute-drafts-list li {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0;
    border-bottom: 1px solid var(--sc-border);
    font-size: 0.875rem;
  }
  .contribute-drafts-list li:last-child { border-bottom: none; }
  .contribute-drafts-list .draft-title { font-weight: 500; color: var(--sc-text); }
  .contribute-drafts-list .draft-meta { font-size: 0.75rem; opacity: 0.9; }
  .contribute-drafts-list .draft-actions { display: inline-flex; align-items: center; gap: 0.5rem; margin-left: 0.5rem; }
  .contribute-drafts-list .draft-actions .contribute-form-btn-secondary { padding: 0.375rem 0.75rem; font-size: 0.8125rem; }
  .contribute-form-sections { display: flex; flex-direction: column; gap: 0; }
  .contribute-form-section {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--sc-border);
    transition: border-color 0.2s ease, background-color 0.2s ease;
    scroll-margin-top: 1rem;
  }
  .contribute-form-section:last-of-type { border-bottom: none; padding-bottom: 0; }
  .contribute-form-section-review { padding-top: 1.75rem; }
  .contribute-form-section-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    background: var(--sc-border);
    color: var(--sc-text-muted);
    transition: background-color 0.2s ease, color 0.2s ease;
  }
  .contribute-form-section-title {
    font-family: var(--font-serif, serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--sc-text);
    margin: 0 0 0.5rem 0;
  }
  .contribute-form-hint {
    font-size: 0.875rem;
    color: var(--sc-text-muted);
    margin: 0 0 1rem 0;
    line-height: 1.45;
  }
  .contribute-form-section-inner { margin-top: 0.25rem; }
  .contribute-form-label {
    display: block;
    font-size: 0.875rem;
    color: var(--sc-text-muted);
    margin-bottom: 0.25rem;
  }
  .contribute-form-input {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border-radius: 0.375rem;
    border: 1px solid var(--sc-border);
    background: var(--sc-bg);
    color: var(--sc-text);
    font-size: 1rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .contribute-form-input:focus {
    outline: none;
    border-color: var(--sc-accent);
    box-shadow: 0 0 0 2px rgba(0, 0, 0, 0.05);
  }
  .contribute-form-input-serif { font-family: var(--font-serif, serif); }
  .contribute-form-input-narrow { max-width: 7rem; }
  .contribute-audio-block {
    padding: 0.75rem 0;
    border-top: 1px solid var(--sc-border);
    margin-top: 0.25rem;
  }
  .contribute-audio-block__title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--sc-text);
    margin: 0 0 0.25rem 0;
  }
  .contribute-audio-block__hint {
    margin-bottom: 0.5rem;
  }
  .contribute-review-preview-label {
    font-size: 0.8125rem;
    color: var(--sc-text-muted);
    margin: 0 0 0.5rem 0;
  }
  .contribute-verse-fieldset {
    border: 1px solid var(--sc-border);
    border-radius: 0.5rem;
    padding: 1rem;
    margin-top: 0.5rem;
    background: var(--sc-bg);
  }
  .contribute-form-legend { font-weight: 500; color: var(--sc-text); padding: 0 0.25rem; }
  .contribute-verses-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem 0;
    font-size: 0.875rem;
    color: var(--sc-text-muted);
  }
  .contribute-verses-list li {
    padding: 0.35rem 0;
    border-bottom: 1px solid var(--sc-border);
    line-height: 1.4;
  }
  .contribute-verses-list li:last-child { border-bottom: none; }
  .contribute-form-field-hint {
    font-size: 0.8125rem;
    color: var(--sc-text-muted);
    margin: 0.125rem 0 0.5rem 0;
    line-height: 1.35;
  }
  /* Review preview: miniatura da página oficial do cântico (mesmas classes que /chants/[slug]) */
  .contribute-review-preview {
    padding: 1rem;
    border-radius: 0.5rem;
    border: 1px solid var(--sc-border);
    background: var(--sc-bg);
    margin-bottom: 1.25rem;
    min-height: 4rem;
    overflow: auto;
  }
  .contribute-review-preview .contribute-review-chant-preview {
    transform-origin: top left;
    font-size: 0.9rem;
  }
  .contribute-review-preview .chant-header__title { font-size: 1.35rem; }
  .contribute-review-preview .prose-chant .original { font-size: 1.15rem; }
  .contribute-review-preview .prose-chant .transliteration { font-size: 1rem; }
  .contribute-review-preview .prose-chant .translations { font-size: 0.9rem; }
  .contribute-form-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .contribute-form-btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.25rem;
    border-radius: 0.5rem;
    border: 1px solid var(--sc-border);
    color: var(--sc-text-muted);
    text-decoration: none;
    font-size: 1rem;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .contribute-form-btn-secondary:hover { border-color: var(--sc-text-muted); color: var(--sc-text); }

  /* ——— Responsive: touch targets, overflow, spacing ——— */
  @media (max-width: 767px) {
    .contribute-form-one-page { max-width: 100%; }
    .contribute-form-section { padding: 1.25rem 0; }
    .contribute-form-section-review { padding-top: 1.5rem; }
    .contribute-form-nav { margin-bottom: 1rem; padding: 0.375rem 0; }
    .contribute-form-nav-link {
      min-height: 2.75rem;
      min-width: 2.75rem;
      padding: 0.5rem 0.75rem;
      display: inline-flex;
      align-items: center;
    }
    .contribute-form-input { padding: 0.625rem 0.75rem; min-height: 2.75rem; }
    .contribute-form-input::-webkit-input-placeholder { font-size: 1rem; }
    .contribute-verse-fieldset { padding: 0.875rem; }
    .contribute-form-actions { gap: 0.5rem; }
    .contribute-form-btn-secondary,
    #btn-add-verse,
    #btn-submit-pr {
      min-height: 2.75rem;
      padding: 0.625rem 1.25rem;
    }
  }
  .contribute-review-preview {
    word-wrap: break-word;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .contribute-verses-list li {
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
</style>

<script define:vars={{ apiOrigin, formT: f, submitSuccessMsg: t.contribute.submitSuccess, viewPR: t.contribute.viewPR }}>
  const root = document.getElementById('contribute-form-root');
  if (root?.getAttribute('data-contribute-app-url')) return;

  const base = (root?.getAttribute('data-api-origin') ?? '') || '';
  const loginRequired = document.getElementById('form-login-required');
  const wizard = document.getElementById('form-wizard');
  const formError = document.getElementById('form-error');
  const formSuccess = document.getElementById('form-success');

  const verses = [];
  const DRAFTS_KEY = 'sacredchants_contribute_drafts';
  const MAX_DRAFTS = 20;
  let currentDraftId = null;

  function getVal(sel) {
    const el = document.querySelector(sel);
    return (el && el.value !== undefined ? el.value : '').trim();
  }

  function escapeHtml(s) {
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }

  function setVal(sel, value) {
    const el = document.querySelector(sel);
    if (!el) return;
    const v = value ?? '';
    if (el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement) {
      el.value = String(v);
    } else if (el instanceof HTMLSelectElement) {
      el.value = String(v);
    }
  }

  function getContentLanguage() {
    return getVal('#content_language') || 'other';
  }

  function hasAudio() {
    if ((getVal('#audio_url') || '').trim()) return true;
    const fileEl = document.getElementById('audio_file');
    return fileEl instanceof HTMLInputElement && fileEl.files && fileEl.files.length > 0;
  }

  function updateVerseStartVisibility() {
    const wrap = document.getElementById('v_start-wrap');
    if (!wrap) return;
    const show = hasAudio();
    wrap.classList.toggle('hidden', !show);
    wrap.setAttribute('aria-hidden', show ? 'false' : 'true');
  }

  function getDrafts() {
    try {
      const raw = localStorage.getItem(DRAFTS_KEY);
      return raw ? JSON.parse(raw) : [];
    } catch {
      return [];
    }
  }

  function setDrafts(list) {
    try {
      localStorage.setItem(DRAFTS_KEY, JSON.stringify(list));
    } catch (_) {}
  }

  function buildDraftFromForm() {
    return {
      id: currentDraftId || 'draft-' + Date.now(),
      updatedAt: new Date().toISOString(),
      slug: getVal('#slug') || '',
      title: getVal('#title') || '',
      tradition: getVal('#tradition') || '',
      language: getVal('#language') || '',
      content_language: getVal('#content_language') || 'other',
      description_en: getVal('#description_en') || '',
      description_pt: getVal('#description_pt') || '',
      tags: getVal('#tags') || '',
      audio_url: getVal('#audio_url') || '',
      interpreter: getVal('#interpreter') || '',
      verses: verses.map((v) => ({
        original: v.original || '',
        transliteration: v.transliteration || '',
        translation_en: v.translation_en || '',
        translation_pt: v.translation_pt || '',
        start: typeof v.start === 'number' ? v.start : 0,
      })),
    };
  }

  function saveDraft() {
    const draft = buildDraftFromForm();
    const list = getDrafts();
    if (currentDraftId) {
      const idx = list.findIndex((d) => d.id === currentDraftId);
      if (idx !== -1) list[idx] = draft;
      else list.unshift(draft);
    } else {
      list.unshift(draft);
    }
    setDrafts(list.slice(0, MAX_DRAFTS));
    currentDraftId = draft.id;
    renderDraftsList();
    if (formSuccess) {
      formSuccess.textContent = formT.draftSaved;
      formSuccess.classList.remove('hidden');
      formError?.classList.add('hidden');
    }
  }

  function loadDraftIntoForm(draft) {
    currentDraftId = draft.id;
    setVal('#slug', draft.slug);
    setVal('#title', draft.title);
    setVal('#tradition', draft.tradition);
    setVal('#language', draft.language);
    setVal('#content_language', draft.content_language || 'other');
    setVal('#description_en', draft.description_en);
    setVal('#description_pt', draft.description_pt);
    setVal('#tags', draft.tags);
    setVal('#audio_url', draft.audio_url);
    setVal('#interpreter', draft.interpreter || '');
    verses.length = 0;
    (draft.verses || []).forEach((v) => {
      verses.push({
        original: v.original || '',
        transliteration: v.transliteration || '',
        translation_en: v.translation_en || undefined,
        translation_pt: v.translation_pt || undefined,
        start: typeof v.start === 'number' ? v.start : 0,
      });
    });
    refreshVersesList();
    updateDescriptionRequired();
    updateVerseTranslationHints();
    updateVerseStartVisibility();
    renderReview();
  }

  function refreshVersesList() {
    const listEl = document.getElementById('verses-list');
    if (!listEl) return;
    listEl.innerHTML = '';
    verses.forEach((v) => {
      const li = document.createElement('li');
      li.textContent = v.transliteration ? v.original + ' — ' + v.transliteration : v.original;
      listEl.appendChild(li);
    });
    const legend = document.getElementById('current-verse-legend');
    if (legend) legend.textContent = formT.verseLegend + ' ' + (verses.length + 1);
  }

  function renderDraftsList() {
    const panel = document.getElementById('drafts-panel');
    const listEl = document.getElementById('drafts-list');
    const emptyEl = document.getElementById('drafts-empty');
    if (!panel || !listEl) return;
    const list = getDrafts();
    listEl.innerHTML = '';
    if (list.length === 0) {
      if (emptyEl) emptyEl.classList.remove('hidden');
      return;
    }
    if (emptyEl) emptyEl.classList.add('hidden');
    list.forEach((d) => {
      const li = document.createElement('li');
      const title = d.title || d.slug || d.id;
      const dateStr = d.updatedAt ? new Date(d.updatedAt).toLocaleString(undefined, { dateStyle: 'short', timeStyle: 'short' }) : '';
      li.innerHTML = '<span class="draft-title">' + escapeHtml(title) + '</span><span class="draft-meta">' + escapeHtml(dateStr) + '</span>';
      const actionsWrap = document.createElement('span');
      actionsWrap.className = 'draft-actions';
      const loadBtn = document.createElement('button');
      loadBtn.type = 'button';
      loadBtn.className = 'contribute-form-btn-secondary';
      loadBtn.textContent = formT.loadDraft;
      loadBtn.addEventListener('click', () => { loadDraftIntoForm(d); document.getElementById('form-section-metadata')?.scrollIntoView({ behavior: 'smooth' }); });
      const delBtn = document.createElement('button');
      delBtn.type = 'button';
      delBtn.className = 'contribute-form-btn-secondary';
      delBtn.textContent = formT.deleteDraft;
      delBtn.addEventListener('click', () => {
        if (!confirm(formT.confirmDeleteDraft)) return;
        const arr = getDrafts().filter((x) => x.id !== d.id);
        setDrafts(arr);
        if (currentDraftId === d.id) currentDraftId = null;
        renderDraftsList();
        if (formSuccess) { formSuccess.textContent = formT.draftDeleted; formSuccess.classList.remove('hidden'); }
      });
      actionsWrap.appendChild(loadBtn);
      actionsWrap.appendChild(delBtn);
      li.appendChild(actionsWrap);
      listEl.appendChild(li);
    });
  }

  function updateDescriptionRequired() {
    const cl = getContentLanguage();
    const descEn = document.getElementById('description_en');
    const descPt = document.getElementById('description_pt');
    if (descEn) descEn.required = cl !== 'en';
    if (descPt) descPt.required = cl !== 'pt';
  }

  function updateVerseTranslationHints() {
    const cl = getContentLanguage();
    const optEn = document.getElementById('verse-translation-en-optional');
    const optPt = document.getElementById('verse-translation-pt-optional');
    if (optEn) {
      optEn.textContent = formT.verseTranslationEnOptionalWhen || '';
      optEn.classList.toggle('hidden', cl !== 'en');
    }
    if (optPt) {
      optPt.textContent = formT.verseTranslationPtOptionalWhen || '';
      optPt.classList.toggle('hidden', cl !== 'pt');
    }
  }

  function renderReview() {
    const title = getVal('#title') || '';
    const tradition = getVal('#tradition') || '';
    const language = getVal('#language') || '';
    const descEn = getVal('#description_en') || '';
    const descPt = getVal('#description_pt') || '';
    const tagsStr = getVal('#tags') || '';
    const tags = tagsStr ? tagsStr.split(',').map((t) => t.trim()).filter(Boolean) : [];
    const container = document.getElementById('review-preview');
    if (!container) return;
    const meta = [tradition, language].filter(Boolean).join(' · ') || '—';
    let html = '';
    html += '<div class="chant-page chant-page__inner chant-page__inner--measure contribute-review-chant-preview">';
    html += '<div class="chant-intro flex flex-col gap-3 pb-6">';
    html += '<header class="chant-header chant-header--centered">';
    html += '<div class="chant-header__top">';
    html += '<p class="chant-header__meta" aria-hidden="true">' + escapeHtml(meta) + '</p>';
    if (title) html += '<h1 class="chant-header__title sc-heading font-serif">' + escapeHtml(title) + '</h1>';
    if (language) html += '<p class="chant-header__lang" aria-hidden="true">' + escapeHtml(language) + '</p>';
    html += '</div>';
    html += '<div class="chant-header__body">';
    if (descEn || descPt) {
      html += '<div class="chant-header__desc">';
      if (descEn) html += '<p class="locale-en mb-0">' + escapeHtml(descEn) + '</p>';
      if (descPt) html += '<p class="locale-pt mb-0">' + escapeHtml(descPt) + '</p>';
      html += '</div>';
    }
    if (tags.length) {
      html += '<ul class="chant-header__tags" aria-label="Tags">';
      tags.forEach((tag) => { html += '<li><span class="chant-header__tag">' + escapeHtml(tag) + '</span></li>'; });
      html += '</ul>';
    }
    const audioUrl = (getVal('#audio_url') || '').trim();
    const hasAudioFile = (() => { const el = document.getElementById('audio_file'); return el instanceof HTMLInputElement && el.files && el.files.length > 0; })();
    if (audioUrl || hasAudioFile) {
      html += '<p class="chant-header__meta mt-2">';
      if (audioUrl) html += 'Audio: <a href="' + escapeHtml(audioUrl) + '" target="_blank" rel="noopener" class="underline">' + escapeHtml(audioUrl) + '</a>';
      else html += 'Audio: <span class="opacity-90">(file will be included)</span>';
      html += '</p>';
      const interpreter = (getVal('#interpreter') || '').trim();
      if (interpreter) html += '<p class="chant-header__meta mt-1">' + escapeHtml(formT.interpretedBy) + ' ' + escapeHtml(interpreter) + '</p>';
    }
    html += '</div></header></div>';
    if (verses.length) {
      html += '<section class="chant-verses" aria-label="Verses">';
      html += '<div class="chant-verses__list prose-chant" id="review-verses-list">';
      verses.forEach((v, idx) => {
        const start = typeof v.start === 'number' && v.start >= 0 ? v.start : 0;
        const startLabel = start > 0 ? ' · ' + Math.floor(start / 60) + ':' + (Math.floor(start % 60) + '').padStart(2, '0') : '';
        html += '<div class="verse-block prose-chant" data-verse="' + (idx + 1) + '">';
        html += '<span class="verse-block__label uppercase tracking-label" aria-hidden="true">Verse ' + (idx + 1) + startLabel + '</span>';
        html += '<p class="original" dir="auto" lang="und">' + escapeHtml(v.original) + '</p>';
        if (v.transliteration) html += '<p class="transliteration" dir="ltr">' + escapeHtml(v.transliteration) + '</p>';
        html += '<div class="translations">';
        if (v.translation_en) html += '<p class="locale-en" data-lang="en">' + escapeHtml(v.translation_en) + '</p>';
        if (v.translation_pt) html += '<p class="locale-pt" data-lang="pt">' + escapeHtml(v.translation_pt) + '</p>';
        html += '</div></div>';
      });
      html += '</div></section>';
    } else {
      html += '<p class="chant-header__meta">' + escapeHtml(formT.reviewEmptyHint) + '</p>';
    }
    html += '</div>';
    container.innerHTML = html;
  }

  function addVerse() {
    const original = getVal('#v_original');
    const transliteration = getVal('#v_transliteration');
    if (!original) {
      if (formError) {
        formError.textContent = formT.verseRequiredError;
        formError.classList.remove('hidden');
        formError.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
      return;
    }
    if (formError) formError.classList.add('hidden');
    const startRaw = getVal('#v_start');
    const start = startRaw === '' ? 0 : Math.max(0, parseFloat(startRaw) || 0);
    verses.push({
      original,
      transliteration,
      translation_en: getVal('#v_translation_en') || undefined,
      translation_pt: getVal('#v_translation_pt') || undefined,
      start,
    });
    const vOriginal = document.getElementById('v_original');
    const vTrans = document.getElementById('v_transliteration');
    const vEn = document.getElementById('v_translation_en');
    const vPt = document.getElementById('v_translation_pt');
    const vStart = document.getElementById('v_start');
    if (vOriginal) vOriginal.value = '';
    if (vTrans) vTrans.value = '';
    if (vEn) vEn.value = '';
    if (vPt) vPt.value = '';
    if (vStart && vStart instanceof HTMLInputElement) vStart.value = '';
    const listEl = document.getElementById('verses-list');
    if (listEl) {
      const li = document.createElement('li');
      li.textContent = transliteration ? original + ' — ' + transliteration : original;
      listEl.appendChild(li);
    }
    const legend = document.getElementById('current-verse-legend');
    if (legend) legend.textContent = formT.verseLegend + ' ' + (verses.length + 1);
    renderReview();
  }

  function buildPayload(audioUrlOrNull) {
    const tagsStr = getVal('#tags');
    const tags = tagsStr ? tagsStr.split(',').map((t) => t.trim()).filter(Boolean) : [];
    const slug = getVal('#slug').toLowerCase().replace(/\s+/g, '-') || '';
    const contentLang = getContentLanguage();
    let descEn = getVal('#description_en') || '';
    let descPt = getVal('#description_pt') || '';
    if (contentLang === 'pt') descPt = descPt || descEn;
    else if (contentLang === 'en') descEn = descEn || descPt;
    const payload = {
      slug,
      title: getVal('#title') || '',
      tradition: getVal('#tradition') || '',
      language: getVal('#language') || '',
      description: { en: descEn, pt: descPt },
      tags,
      ...(audioUrlOrNull && { audio: audioUrlOrNull }),
      ...(getVal('#interpreter')?.trim() && { interpreter: getVal('#interpreter').trim() }),
      verses: verses.map((v, i) => {
        let en = v.translation_en;
        let pt = v.translation_pt;
        if (contentLang === 'pt') pt = pt || v.original;
        else if (contentLang === 'en') en = en || v.original;
        const transliteration = (v.transliteration || '').trim() || undefined;
        const start = typeof v.start === 'number' && v.start >= 0 ? v.start : 0;
        return {
          order: i + 1,
          lines: [{
            start,
            original: v.original,
            ...(transliteration !== undefined && { transliteration }),
            translations: { en: en || '', pt: pt || '' },
          }],
        };
      }),
    };
    return payload;
  }

  function getAudioForPayload() {
    const url = (getVal('#audio_url') || '').trim();
    const fileInput = document.getElementById('audio_file');
    if (fileInput instanceof HTMLInputElement && fileInput.files && fileInput.files.length > 0) {
      return { type: 'file', file: fileInput.files[0] };
    }
    if (url) return { type: 'url', url };
    return null;
  }

  function submitPR() {
    const contentLang = getContentLanguage();
    const requiredSelectors = ['#slug', '#title', '#tradition', '#language'];
    if (contentLang === 'other') requiredSelectors.push('#description_en', '#description_pt');
    else if (contentLang === 'pt') requiredSelectors.push('#description_en');
    else requiredSelectors.push('#description_pt');
    const invalidEl = requiredSelectors.map((sel) => document.querySelector(sel)).find(
      (el) => (el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement) && !el.checkValidity()
    );
    if (invalidEl) {
      invalidEl.reportValidity();
      invalidEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      return;
    }
    if (verses.length === 0) {
      if (formError) {
        formError.textContent = formT.verseMinSubmitError;
        formError.classList.remove('hidden');
        formError.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
      return;
    }
    const btn = document.getElementById('btn-submit-pr');
    if (btn) btn.disabled = true;
    if (formError) formError.classList.add('hidden');
    const audioInfo = getAudioForPayload();
    if (audioInfo && audioInfo.type === 'file') {
      const file = audioInfo.file;
      const reader = new FileReader();
      reader.onload = function() {
        const b64 = typeof reader.result === 'string' ? reader.result.replace(/^data:[^;]+;base64,/, '') : null;
        if (!b64) {
          if (formError) { formError.textContent = formT.audioReadError; formError.classList.remove('hidden'); }
          if (btn) btn.disabled = false;
          return;
        }
        const slug = getVal('#slug').toLowerCase().replace(/\s+/g, '-') || '';
        const ext = file.name.split('.').pop()?.toLowerCase() || 'mp3';
        const payload = buildPayload(null);
        payload.audioBase64 = b64;
        payload.audioFilename = slug + '.' + ext;
        sendPayload(payload, btn);
      };
      reader.readAsDataURL(file);
      return;
    }
    const audioUrl = audioInfo && audioInfo.type === 'url' ? audioInfo.url : null;
    const payload = buildPayload(audioUrl);
    sendPayload(payload, btn);
  }

  function sendPayload(payload, btn) {
    fetch(base + '/api/contribute/submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      body: JSON.stringify(payload),
    })
      .then((res) => res.json().catch(() => ({})))
      .then((data) => {
        if (data.prUrl) {
          formSuccess.textContent = submitSuccessMsg + ' ';
          const link = document.createElement('a');
          link.href = data.prUrl;
          link.target = '_blank';
          link.rel = 'noopener';
          link.textContent = viewPR;
          formSuccess.appendChild(link);
          formSuccess.classList.remove('hidden');
          formSuccess.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        } else {
          const errMsg = data.error || (typeof data.details === 'object' && data.details !== null ? JSON.stringify(data.details) : data.details) || 'Request failed';
          formError.textContent = errMsg;
          formError.classList.remove('hidden');
          formError.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      })
      .catch((err) => {
        formError.textContent = err instanceof Error ? err.message : 'Request failed';
        formError.classList.remove('hidden');
        formError.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      })
      .finally(() => { if (btn) btn.disabled = false; });
  }

  function setupLiveReview() {
    const fields = ['#slug', '#title', '#tradition', '#language', '#description_en', '#description_pt', '#tags', '#audio_url', '#interpreter', '#content_language'];
    fields.forEach((sel) => {
      const el = document.querySelector(sel);
      if (el) {
        el.addEventListener('input', () => { updateVerseStartVisibility(); renderReview(); });
      }
    });
    const audioFileEl = document.getElementById('audio_file');
    if (audioFileEl) audioFileEl.addEventListener('change', () => { updateVerseStartVisibility(); renderReview(); });
    const contentLangEl = document.getElementById('content_language');
    if (contentLangEl) {
      contentLangEl.addEventListener('change', () => {
        updateDescriptionRequired();
        updateVerseTranslationHints();
        renderReview();
      });
    }
  }

  function setupContentLanguage() {
    updateDescriptionRequired();
    updateVerseTranslationHints();
  }

  function setupNav() {
    const sections = [
      { id: 'form-section-metadata', key: 'metadata' },
      { id: 'form-section-verses', key: 'verses' },
      { id: 'form-section-review', key: 'review' },
    ];
    const navLinks = document.querySelectorAll('.contribute-form-nav-link');
    navLinks.forEach((link) => {
      link.addEventListener('click', (e) => {
        const sectionId = link.getAttribute('href')?.slice(1);
        const el = sectionId ? document.getElementById(sectionId) : null;
        if (el) {
          e.preventDefault();
          el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const id = entry.target.id;
          const key = sections.find((s) => s.id === id)?.key;
          navLinks.forEach((a) => {
            const isCurrent = a.getAttribute('data-section') === key;
            a.classList.toggle('is-current', isCurrent);
            if (isCurrent) {
              a.setAttribute('aria-current', 'location');
            } else {
              a.removeAttribute('aria-current');
            }
          });
        });
      },
      { rootMargin: '-20% 0px -60% 0px', threshold: 0 }
    );
    sections.forEach((s) => {
      const el = document.getElementById(s.id);
      if (el) observer.observe(el);
    });
    navLinks[0]?.classList.add('is-current');
    navLinks[0]?.setAttribute('aria-current', 'location');
  }

  fetch(base + '/api/me', { credentials: 'include' })
    .then((r) => (r.ok ? r.json() : null))
    .then((user) => {
      if (user && user.login) {
        if (loginRequired) loginRequired.classList.add('hidden');
        if (wizard) wizard.classList.remove('hidden');
        const draftsPanel = document.getElementById('drafts-panel');
        if (draftsPanel) draftsPanel.classList.remove('hidden');
        renderDraftsList();
        const draftId = new URLSearchParams(window.location.search).get('draft');
        if (draftId) {
          const list = getDrafts();
          const d = list.find((x) => x.id === draftId);
          if (d) {
            loadDraftIntoForm(d);
            document.getElementById('form-section-metadata')?.scrollIntoView({ behavior: 'smooth' });
          }
        }
        setupLiveReview();
        setupContentLanguage();
        updateVerseStartVisibility();
        renderReview();
        setupNav();
      }
    })
    .catch(() => {});

  document.getElementById('btn-add-verse')?.addEventListener('click', addVerse);
  document.getElementById('btn-submit-pr')?.addEventListener('click', submitPR);
  document.getElementById('btn-save-draft')?.addEventListener('click', saveDraft);
</script>
