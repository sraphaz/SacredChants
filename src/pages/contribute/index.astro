---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import { ui, type Locale } from '../../i18n/strings';

const locale = (Astro.url.searchParams.get('lang') === 'pt' ? 'pt' : 'en') as Locale;
const t = ui[locale];
const apiOrigin = import.meta.env.PUBLIC_CONTRIBUTE_API_ORIGIN ?? '';
const contributeAppUrl = (import.meta.env.PUBLIC_CONTRIBUTE_APP_URL as string)?.trim() ?? '';
const useAppSubdomain = contributeAppUrl.length > 0;
const contributeAppBase = useAppSubdomain ? `${contributeAppUrl.replace(/\/$/, '')}/contribute/` : '';
const contributeAppContributeUrl = useAppSubdomain ? contributeAppBase + (locale === 'pt' ? '?lang=pt' : '') : '';
const returnToContribute = locale === 'pt' ? '/contribute/?lang=pt' : '/contribute/';
---

<BaseLayout
  title={t.contribute.title}
  description={t.contribute.description}
  locale={locale}
>
  <PageShell>
    <h1 class="font-serif text-sc-3xl sc-heading mb-page-heading">
      {t.contribute.title}
    </h1>

    <div id="contribute-root" class:list={['space-y-6', !useAppSubdomain && 'contribute-auth-pending']} data-api-origin={apiOrigin} data-contribute-app-url={contributeAppContributeUrl || undefined}>
      {useAppSubdomain ? (
        <div class="mb-page-content">
          <p class="mb-3" style="color: var(--sc-text-muted)">
            {t.contribute.useContributeApp}
          </p>
          <a
            href={contributeAppContributeUrl}
            class="sc-btn-primary inline-flex items-center gap-2 px-5 py-2.5 rounded-lg transition"
            aria-label={t.contribute.openContributeApp}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
            <span>{t.contribute.openContributeApp}</span>
          </a>
        </div>
      ) : (
        <>
          <p class="mb-page-content" style="color: var(--sc-text-muted)">
            {t.contribute.loginToContribute}
          </p>
          <div id="contribute-login-cta">
            <a
              href={`${apiOrigin}/api/auth/github?returnTo=${encodeURIComponent(returnToContribute)}`}
              class="sc-btn-primary inline-flex items-center gap-2 px-5 py-2.5 rounded-lg transition"
            >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          <span>{t.contribute.signInWithGitHub}</span>
        </a>
      </div>
      <div id="contribute-authenticated" class="hidden">
        <p class="mb-3" style="color: var(--sc-text)" id="contribute-welcome-msg"></p>
        <div role="tablist" class="flex gap-1 mb-4 border-b" style="border-color: var(--sc-border)" aria-label={t.contribute.title}>
          <button type="button" role="tab" id="tab-new" aria-selected="true" aria-controls="panel-new" class="contribute-tab px-4 py-2 rounded-t text-sm font-medium transition" style="color: var(--sc-text-muted)">{t.contribute.newContribution}</button>
          <button type="button" role="tab" id="tab-mine" aria-selected="false" aria-controls="panel-mine" class="contribute-tab px-4 py-2 rounded-t text-sm font-medium transition" style="color: var(--sc-text-muted)">{t.contribute.myContributions}</button>
        </div>
        <div id="panel-new" role="tabpanel" aria-labelledby="tab-new" class="contribute-panel">
          <p class="mb-3" style="color: var(--sc-text-muted)">{t.contribute.newContributionIntro}</p>
          <a href={locale === 'pt' ? '/contribute/form/?lang=pt' : '/contribute/form/'} class="sc-btn-primary inline-flex items-center gap-2 px-5 py-2.5 rounded-lg transition">
            {t.contribute.newContribution}
          </a>
        </div>
        <div id="panel-mine" role="tabpanel" aria-labelledby="tab-mine" class="contribute-panel hidden" aria-hidden="true">
          <p id="contribute-empty" class="hidden mb-3" style="color: var(--sc-text-muted)">{t.contribute.noContributionsYet}</p>
          <ul id="contribute-list" class="space-y-3 mb-4" aria-label={t.contribute.myContributions}></ul>
          <a href={locale === 'pt' ? '/contribute/form/?lang=pt' : '/contribute/form/'} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg transition" style="color: var(--sc-text-muted); border: 1px solid var(--sc-border)">{t.contribute.newContribution}</a>
        </div>
        <form id="contribute-logout-form" action={`${apiOrigin}/api/logout`} method="post" class="inline mt-4 block">
          <button type="submit" class="inline text-sm" style="color: var(--sc-text-muted)">
            {t.contribute.signOut}
          </button>
        </form>
      </div>
      </>
      )}
    </div>

    <div class="mt-section-gap pt-6 border-t" style="border-color: var(--sc-border)">
      <h2 class="font-serif text-sc-xl sc-heading mb-4" style="color: var(--sc-text)">Developer option</h2>
      <p class="mb-4" style="color: var(--sc-text-muted)">
        You can also add a chant by creating a JSON file and opening a pull request. See the schema in <code class="px-1 rounded" style="background-color: var(--sc-border)">src/content/schemas/chant.ts</code>.
      </p>
    </div>
  </PageShell>
    <style>
      #contribute-root.contribute-auth-pending #contribute-login-cta,
      #contribute-root.contribute-auth-pending #contribute-authenticated {
        opacity: 0;
        pointer-events: none;
      }
      .contribute-tab[aria-selected="true"] { color: var(--sc-text); border-bottom: 2px solid var(--sc-accent); margin-bottom: -1px; }
      .contribute-tab {
        min-height: 2.75rem;
        padding: 0.5rem 0.75rem;
        flex: 1 1 auto;
        min-width: 0;
      }
      #contribute-list li {
        word-wrap: break-word;
        overflow-wrap: break-word;
      }
      @media (max-width: 767px) {
        [role="tablist"] { flex-wrap: wrap; gap: 0.25rem; }
        .contribute-tab { min-width: 8rem; }
        #contribute-list li { flex-direction: column; align-items: flex-start; gap: 0.25rem; }
      }
    </style>
</BaseLayout>

<script define:vars={{ apiOrigin, stateOpen: t.contribute.stateOpen, stateMerged: t.contribute.stateMerged, stateClosed: t.contribute.stateClosed, viewPR: t.contribute.viewPR, noContributionsYet: t.contribute.noContributionsYet }}>
  const root = document.getElementById('contribute-root');
  if (root?.getAttribute('data-contribute-app-url')) return;
  const loginCta = document.getElementById('contribute-login-cta');
  const authenticated = document.getElementById('contribute-authenticated');
  const welcomeMsg = document.getElementById('contribute-welcome-msg');
  const base = apiOrigin || '';

  const tabNew = document.getElementById('tab-new');
  const tabMine = document.getElementById('tab-mine');
  const panelNew = document.getElementById('panel-new');
  const panelMine = document.getElementById('panel-mine');
  const listEl = document.getElementById('contribute-list');
  const emptyEl = document.getElementById('contribute-empty');

  function showPanel(which) {
    const isNew = which === 'new';
    if (tabNew) tabNew.setAttribute('aria-selected', isNew ? 'true' : 'false');
    if (tabMine) tabMine.setAttribute('aria-selected', !isNew ? 'true' : 'false');
    if (panelNew) {
      panelNew.classList.toggle('hidden', !isNew);
      panelNew.setAttribute('aria-hidden', isNew ? 'false' : 'true');
    }
    if (panelMine) {
      panelMine.classList.toggle('hidden', isNew);
      panelMine.setAttribute('aria-hidden', isNew ? 'true' : 'false');
    }
  }

  tabNew?.addEventListener('click', () => showPanel('new'));
  tabMine?.addEventListener('click', () => showPanel('mine'));

  fetch(base + '/api/me', { credentials: 'include' })
    .then((r) => (r.ok ? r.json() : null))
    .then((user) => {
      root?.classList.remove('contribute-auth-pending');
      if (user && user.login) {
        if (loginCta) loginCta.classList.add('hidden');
        if (authenticated) authenticated.classList.remove('hidden');
        if (welcomeMsg) welcomeMsg.textContent = `${document.documentElement.lang === 'pt' ? 'Bem-vindo(a)' : 'Welcome'}, @${user.login}`;
        return fetch(base + '/api/contribute/list', { credentials: 'include' });
      }
    })
    .then((res) => (res?.ok ? res.json() : null))
    .then((data) => {
      const contributions = data?.contributions ?? [];
      if (listEl) {
        listEl.innerHTML = '';
        contributions.forEach((c) => {
          const li = document.createElement('li');
          li.className = 'flex flex-wrap items-center gap-2 py-2 border-b';
          li.style.borderColor = 'var(--sc-border)';
          const stateLabel = c.merged ? stateMerged : c.state === 'open' ? stateOpen : stateClosed;
          const numSpan = document.createElement('span');
          numSpan.className = 'font-medium';
          numSpan.textContent = '#' + c.number;
          li.appendChild(numSpan);
          li.appendChild(document.createTextNode(' ' + (c.title || '') + ' — '));
          const stateSpan = document.createElement('span');
          stateSpan.style.color = 'var(--sc-text-muted)';
          stateSpan.textContent = stateLabel;
          li.appendChild(stateSpan);
          const link = document.createElement('a');
          link.href = (c.htmlUrl && typeof c.htmlUrl === 'string') ? c.htmlUrl : '#';
          link.target = '_blank';
          link.rel = 'noopener';
          link.className = 'ml-2 underline';
          link.textContent = viewPR;
          li.appendChild(document.createTextNode(' '));
          li.appendChild(link);
          listEl.appendChild(li);
        });
      }
      if (emptyEl) emptyEl.classList.toggle('hidden', contributions.length > 0);
    })
    .catch(() => {
      root?.classList.remove('contribute-auth-pending');
      if (emptyEl) emptyEl.classList.remove('hidden');
    });
</script>
