---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import { getCollection } from 'astro:content';
import { ui, getLocaleFromUrl, langQuery } from '../../i18n/strings';

import { getFullBase } from '../../utils/base';
const FULL_BASE = getFullBase(Astro.url);
const locale = getLocaleFromUrl(Astro.url.searchParams);
const localeQuery = langQuery(locale);
const tEn = ui.en;
const tPt = ui.pt;
const tEs = ui.es;
const tIt = ui.it;
const titleMap = { en: tEn.traditions.title, pt: tPt.traditions.title, es: tEs.traditions.title, it: tIt.traditions.title };
const descMap = { en: tEn.traditions.description, pt: tPt.traditions.description, es: tEs.traditions.description, it: tIt.traditions.description };
const chants = await getCollection('chants');
const traditions = [...new Set(chants.map((c) => c.data.tradition))].sort();
---

<BaseLayout
  title={titleMap[locale]}
  description={descMap[locale]}
  locale={locale}
>
  <PageShell>
    <h1 class="font-serif text-sc-3xl sc-heading mb-page-heading">
      <span class="locale-en">{tEn.traditions.title}</span>
      <span class="locale-pt">{tPt.traditions.title}</span>
      <span class="locale-es">{tEs.traditions.title}</span>
      <span class="locale-it">{tIt.traditions.title}</span>
    </h1>
    <p class="mb-page-content" style="color: var(--sc-text-muted)">
      <span class="locale-en">{tEn.traditions.description}</span>
      <span class="locale-pt">{tPt.traditions.description}</span>
      <span class="locale-es">{tEs.traditions.description}</span>
      <span class="locale-it">{tIt.traditions.description}</span>
    </p>
    {traditions.length > 0 ? (
      <ul class="space-y-3">
        {traditions.map((tradition) => (
          <li>
            <a
              href={`${FULL_BASE}chants/?tradition=${encodeURIComponent(tradition)}${localeQuery ? '&' + localeQuery.slice(1) : ''}`}
              class="block py-2 font-medium transition-colors"
              style="color: var(--sc-text-muted)"
            >
              {tradition}
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p style="color: var(--sc-text-subtle)">
        <span class="locale-en">{tEn.traditions.noTraditionsYet}</span>
        <span class="locale-pt">{tPt.traditions.noTraditionsYet}</span>
        <span class="locale-es">{tEs.traditions.noTraditionsYet}</span>
        <span class="locale-it">{tIt.traditions.noTraditionsYet}</span>
      </p>
    )}
  </PageShell>
</BaseLayout>
