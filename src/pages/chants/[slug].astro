---
import ChantLayout from '../../layouts/ChantLayout.astro';
import ChantHeader from '../../components/ChantHeader.astro';
import ChantVerse from '../../components/ChantVerse.astro';
import ChantPlayerBar from '../../components/ChantPlayerBar.astro';
import SaveOfflineToggle from '../../components/SaveOfflineToggle.astro';
import { getEntry, getCollection } from 'astro:content';
import { ui, getLocaleFromUrl, SUPPORTED_LOCALES } from '../../i18n/strings';
import { getBandcampArtUrl } from '../../utils/bandcamp';
import { getFullBase } from '../../utils/base';
import { buildCanonicalPageUrl } from '../../utils/offline-page-url';
import {
  getAudioUrl,
  getSyncLines,
  getLinesWithMeta,
  hasTranslation,
} from '../../utils/chant-page';

export async function getStaticPaths() {
  const chants = await getCollection('chants');
  return chants.map((entry) => ({
    params: { slug: entry.id },
    props: { chant: { ...entry.data, slug: entry.id } },
  }));
}

const { slug } = Astro.params;
const locale = getLocaleFromUrl(Astro.url.searchParams);
const tEn = ui.en;
const tPt = ui.pt;
const tEs = ui.es;
const tIt = ui.it;
const tHi = ui.hi;
const tAr = ui.ar;

const entry = await getEntry('chants', slug!);
if (!entry) {
  return Astro.redirect('/chants');
}

const chant = { ...entry.data, slug: entry.id };

const FULL_BASE = getFullBase(Astro.url);
const pageUrlForOffline = buildCanonicalPageUrl(
  Astro.url.origin,
  Astro.url.pathname,
  Astro.url.search
);
const audioUrlForPlayer = getAudioUrl(chant, FULL_BASE);

const bandcampArtImage =
  chant.bandcampArtImage ??
  (chant.bandcampUrl ? await getBandcampArtUrl(chant.bandcampUrl) : undefined);

const syncLines = getSyncLines(chant);
const hasSync = Boolean(chant.audio && syncLines.length > 0);
const linesWithMeta = getLinesWithMeta(chant);
const hasEs = hasTranslation(chant, 'es');
const hasIt = hasTranslation(chant, 'it');
const hasHi = hasTranslation(chant, 'hi');
const hasAr = hasTranslation(chant, 'ar');

---

<ChantLayout chant={chant} locale={locale}>
  {chant.audio && audioUrlForPlayer && (
    <>
      <ChantPlayerBar
        audioUrl={audioUrlForPlayer}
        title={chant.title}
        hasSync={hasSync}
        syncLabelEn={tEn.chant.syncLabel}
        syncLabelPt={tPt.chant.syncLabel}
        syncLabelEs={tEs.chant.syncLabel}
        syncLabelIt={tIt.chant.syncLabel}
        syncLabelHi={tHi.chant.syncLabel}
        syncLabelAr={tAr.chant.syncLabel}
        syncOnEn={tEn.chant.syncOn}
        syncOffEn={tEn.chant.syncOff}
        syncOnPt={tPt.chant.syncOn}
        syncOffPt={tPt.chant.syncOff}
        syncOnEs={tEs.chant.syncOn}
        syncOffEs={tEs.chant.syncOff}
        syncOnIt={tIt.chant.syncOn}
        syncOffIt={tIt.chant.syncOff}
        syncOnHi={tHi.chant.syncOn}
        syncOffHi={tHi.chant.syncOff}
        syncOnAr={tAr.chant.syncOn}
        syncOffAr={tAr.chant.syncOff}
        bandcampUrl={chant.bandcampUrl}
        bandcampEmbedSrc={chant.bandcampEmbedSrc}
        bandcampArtImage={bandcampArtImage}
        bandcampTooltipEn="Listen on Bandcamp"
        bandcampTooltipPt="Ouvir no Bandcamp"
        bandcampTooltipEs="Escuchar en Bandcamp"
        bandcampTooltipIt="Ascolta su Bandcamp"
        bandcampTooltipHi="Bandcamp पर सुनें"
        bandcampTooltipAr="الاستماع على Bandcamp"
        locale={locale}
      />
      <div class="chant-player-bar-spacer hidden md:block"></div>
      <script is:inline>
        (function() {
          var audio = document.getElementById('chant-audio');
          if (!audio) return;
          var p = new URLSearchParams(window.location.search);
          var wantSync = p.get('sync') === '1' || p.get('sync') === 'true';
          var wantAutoplay = p.get('autoplay') === '1' || p.get('autoplay') === 'true';
          if (wantSync) {
            try { localStorage.setItem('chant-sync-enabled', 'true'); } catch (e) {}
          }
          if (wantAutoplay) {
            var playWhenReady = function() {
              audio.play().catch(function() {});
            };
            if (audio.readyState >= 2) {
              playWhenReady();
            } else {
              audio.addEventListener('canplay', playWhenReady, { once: true });
            }
          }
        })();
      </script>
    </>
  )}
  <div class="chant-intro flex flex-col gap-3 pb-6">
    <ChantHeader chant={chant} />
    <nav class="chant-actions flex flex-wrap items-center justify-center gap-x-6 gap-y-1 text-sm" aria-label="Actions">
      <button
        type="button"
        id="chant-download-pdf-btn"
        class="chant-action-link inline-flex items-center gap-1.5 py-1 cursor-pointer border-0 bg-transparent transition-colors hover:opacity-90"
        style="color: var(--sc-text-muted);"
      >
        <span aria-hidden="true">📄</span>
        <span class="locale-en">{tEn.chant.downloadPdf}</span>
        <span class="locale-pt">{tPt.chant.downloadPdf}</span>
        <span class="locale-es">{tEs.chant.downloadPdf}</span>
        <span class="locale-it">{tIt.chant.downloadPdf}</span>
        <span class="locale-hi">{tHi.chant.downloadPdf}</span>
        <span class="locale-ar">{tAr.chant.downloadPdf}</span>
      </button>
      <SaveOfflineToggle
        mode="chantButton"
        storageSlug={chant.slug}
        pageUrl={pageUrlForOffline}
        audioUrl={audioUrlForPlayer || undefined}
        buttonId="chant-save-offline-btn"
        feedbackElementId="chant-offline-feedback"
      />
      {chant.spotifyUrl && (
        <a
          href={chant.spotifyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="chant-action-link inline-flex items-center gap-1.5 py-1 transition-colors hover:opacity-90"
          style="color: var(--sc-text-muted);"
        >
          <span aria-hidden="true">♫</span>
          <span class="locale-en">{tEn.chant.listenOnSpotify}</span>
          <span class="locale-pt">{tPt.chant.listenOnSpotify}</span>
          <span class="locale-es">{tEs.chant.listenOnSpotify}</span>
          <span class="locale-it">{tIt.chant.listenOnSpotify}</span>
          <span class="locale-hi">{tHi.chant.listenOnSpotify}</span>
          <span class="locale-ar">{tAr.chant.listenOnSpotify}</span>
        </a>
      )}
      {!chant.audio && chant.bandcampUrl && (
        <a href={chant.bandcampUrl} target="_blank" rel="noopener noreferrer" class="chant-action-link chant-bar-bandcamp inline-flex items-center gap-1.5 py-1 transition-colors hover:opacity-90" title="Bandcamp" aria-label="Bandcamp">
          <svg class="chant-bar-bandcamp-icon chant-bar-bandcamp-icon--shape" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
            <circle cx="12" cy="12" r="12" fill="#000"/>
            <polygon points="5,9 19,9 17,15 3,15" fill="#fff"/>
          </svg>
        </a>
      )}
      {chant.audio && (
        <a
          href={`${FULL_BASE}chants/${chant.slug}?autoplay=1&sync=1`}
          class="chant-action-link inline-flex items-center gap-1.5 py-1 transition-colors hover:opacity-90"
          style="color: var(--sc-text-muted);"
          title="Copy or share this link so the chant opens with audio playing and lyrics sync on"
        >
          <span aria-hidden="true">🔗</span>
          <span class="locale-en">{tEn.chant.shareWithAutoplay}</span>
          <span class="locale-pt">{tPt.chant.shareWithAutoplay}</span>
          <span class="locale-es">{tEs.chant.shareWithAutoplay}</span>
          <span class="locale-it">{tIt.chant.shareWithAutoplay}</span>
          <span class="locale-hi">{tHi.chant.shareWithAutoplay}</span>
          <span class="locale-ar">{tAr.chant.shareWithAutoplay}</span>
        </a>
      )}
      <SaveOfflineToggle
        mode="chantFeedback"
        storageSlug={chant.slug}
        feedbackElementId="chant-offline-feedback"
      />
    </nav>
  </div>
  {(!hasEs || !hasIt || !hasHi || !hasAr) && (
    <p class="chant-translation-fallback mb-4 px-2 py-2 rounded text-sm" style="background: var(--sc-bg-muted, #f0f0f0); color: var(--sc-text-muted, #666);" role="status">
      {!hasEs && <span class="locale-es">{tEs.chant.translationFallback}</span>}
      {!hasIt && <span class="locale-it">{tIt.chant.translationFallback}</span>}
      {!hasHi && <span class="locale-hi">{tHi.chant.translationFallback}</span>}
      {!hasAr && <span class="locale-ar">{tAr.chant.translationFallback}</span>}
    </p>
  )}
  <section class="chant-verses" aria-label="Verses">
      <div class="chant-verses__list" id="chant-verses-list" data-sync-lines={JSON.stringify(syncLines)}>
        {linesWithMeta.map(({ verse, line, syncIndex, showVerseLabel, showExplanation }) => (
          <ChantVerse verse={verse} line={line} syncIndex={syncIndex} showVerseLabel={showVerseLabel} showExplanation={showExplanation} />
        ))}
      </div>
    </section>

    {(chant.about?.en || chant.about?.pt || chant.about?.es || chant.about?.it || chant.about?.hi || chant.about?.ar) && (
    <section class="chant-about mt-section-gap mb-section" aria-labelledby="chant-about-title">
      <h2 id="chant-about-title" class="chant-about__title sc-heading font-serif mb-4">
        <span class="locale-en">{tEn.chant.aboutTitle}</span>
        <span class="locale-pt">{tPt.chant.aboutTitle}</span>
        <span class="locale-es">{tEs.chant.aboutTitle}</span>
        <span class="locale-it">{tIt.chant.aboutTitle}</span>
        <span class="locale-hi">{tHi.chant.aboutTitle}</span>
        <span class="locale-ar">{tAr.chant.aboutTitle}</span>
      </h2>
      {chant.about?.en && (
        <div class="chant-about__body locale-en">
          {chant.about.en}
        </div>
      )}
      {chant.about?.pt && (
        <div class="chant-about__body locale-pt mt-4">
          {chant.about.pt}
        </div>
      )}
      {chant.about?.es && (
        <div class="chant-about__body locale-es mt-4">
          {chant.about.es}
        </div>
      )}
      {chant.about?.it && (
        <div class="chant-about__body locale-it mt-4">
          {chant.about.it}
        </div>
      )}
      {chant.about?.hi && (
        <div class="chant-about__body locale-hi mt-4">
          {chant.about.hi}
        </div>
      )}
      {chant.about?.ar && (
        <div class="chant-about__body locale-ar mt-4" dir="rtl">
          {chant.about.ar}
        </div>
      )}
    </section>
    )}

  <script is:inline>
    document.getElementById('chant-download-pdf-btn')?.addEventListener('click', function() { window.print(); });
  </script>
  {hasSync && (
    <script is:inline define:vars={{ syncLocalesJson: JSON.stringify([...SUPPORTED_LOCALES]) }}>
      (function() {
        var STORAGE_KEY = 'chant-sync-enabled';
        var audio = document.getElementById('chant-audio');
        var list = document.getElementById('chant-verses-list');
        var toggleBtn = document.getElementById('chant-sync-toggle');
        var stateEl = document.getElementById('chant-sync-toggle-state');
        var stateElPt = document.getElementById('chant-sync-toggle-state-pt');
        var stateElEs = document.getElementById('chant-sync-toggle-state-es');
        var stateElIt = document.getElementById('chant-sync-toggle-state-it');
        var stateElHi = document.getElementById('chant-sync-toggle-state-hi');
        var stateElAr = document.getElementById('chant-sync-toggle-state-ar');
        var syncLinesRaw = list && list.getAttribute('data-sync-lines');
        var syncLines = [];
        try { if (syncLinesRaw) syncLines = JSON.parse(syncLinesRaw); } catch (e) {}
        if (!audio || !list || !syncLines.length) return;
        var blocks = list.querySelectorAll('.verse-block[data-sync-index]');
        var lastActiveIndex = -1;

        var SYNC_LOCALES = [];
        try { SYNC_LOCALES = JSON.parse(syncLocalesJson); } catch (e) { SYNC_LOCALES = ['en','pt','es','it','hi','ar']; }
        var syncOnBy = {};
        var syncOffBy = {};
        var labelBy = {};
        for (var si = 0; si < SYNC_LOCALES.length; si++) {
          var loc = SYNC_LOCALES[si];
          if (!toggleBtn) continue;
          syncOnBy[loc] = toggleBtn.getAttribute('data-sync-on-' + loc);
          syncOffBy[loc] = toggleBtn.getAttribute('data-sync-off-' + loc);
          labelBy[loc] = toggleBtn.getAttribute('data-sync-label-' + loc);
        }
        var defOn = syncOnBy.en || 'On';
        var defOff = syncOffBy.en || 'Off';
        var defLabel = labelBy.en || 'Sync';
        for (var sj = 0; sj < SYNC_LOCALES.length; sj++) {
          var loc2 = SYNC_LOCALES[sj];
          if (!syncOnBy[loc2]) syncOnBy[loc2] = defOn;
          if (!syncOffBy[loc2]) syncOffBy[loc2] = defOff;
          if (!labelBy[loc2]) labelBy[loc2] = defLabel;
        }

        function getSyncEnabled() {
          try {
            var v = localStorage.getItem(STORAGE_KEY);
            return v !== 'false';
          } catch (e) { return true; }
        }
        function updateSyncAriaLabel(on) {
          if (!toggleBtn) return;
          var locale = (document.documentElement.dataset && document.documentElement.dataset.locale) || 'en';
          var label = labelBy[locale] || defLabel;
          var state = on ? (syncOnBy[locale] || defOn) : (syncOffBy[locale] || defOff);
          toggleBtn.setAttribute('aria-label', label + ' — ' + state);
        }
        function updateCylindrical() {
          var on = getSyncEnabled() && audio && !audio.paused;
          if (list) list.setAttribute('data-sync-cylindrical', on ? 'true' : '');
        }
        function setSyncEnabled(on) {
          try { localStorage.setItem(STORAGE_KEY, on ? 'true' : 'false'); } catch (e) {}
          updateCylindrical();
          if (toggleBtn) {
            toggleBtn.setAttribute('aria-pressed', on ? 'true' : 'false');
            toggleBtn.setAttribute('data-sync-on', on ? 'true' : '');
            if (stateEl) stateEl.textContent = on ? (syncOnBy.en || defOn) : (syncOffBy.en || defOff);
            if (stateElPt) stateElPt.textContent = on ? (syncOnBy.pt || defOn) : (syncOffBy.pt || defOff);
            if (stateElEs) stateElEs.textContent = on ? (syncOnBy.es || defOn) : (syncOffBy.es || defOff);
            if (stateElIt) stateElIt.textContent = on ? (syncOnBy.it || defOn) : (syncOffBy.it || defOff);
            if (stateElHi) stateElHi.textContent = on ? (syncOnBy.hi || defOn) : (syncOffBy.hi || defOff);
            if (stateElAr) stateElAr.textContent = on ? (syncOnBy.ar || defOn) : (syncOffBy.ar || defOff);
            updateSyncAriaLabel(on);
          }
          if (!on) clearActive();
        }

        function getCurrentLineIndex(time) {
          if (time < syncLines[0].start) return 0;
          for (var i = 0; i < syncLines.length; i++) {
            var nextStart = i + 1 < syncLines.length ? syncLines[i + 1].start : Infinity;
            if (time >= syncLines[i].start && time < nextStart) return i;
          }
          return syncLines.length - 1;
        }
        function clearActive() {
          blocks.forEach(function(el) {
            el.classList.remove('verse-block--active', 'verse-block--before', 'verse-block--after');
          });
        }
        function setActive(index, scroll) {
          blocks.forEach(function(el) {
            var i = Number(el.getAttribute('data-sync-index'));
            el.classList.remove('verse-block--active', 'verse-block--before', 'verse-block--after');
            if (i === index) {
              el.classList.add('verse-block--active');
              if (scroll) el.scrollIntoView({ behavior: 'smooth', block: 'center' });
            } else if (i < index) {
              el.classList.add('verse-block--before');
            } else {
              el.classList.add('verse-block--after');
            }
          });
        }

        var syncEnabled = getSyncEnabled();
        setSyncEnabled(syncEnabled);
        if (syncEnabled) {
          var idx = getCurrentLineIndex(audio.currentTime);
          if (idx != null) { lastActiveIndex = idx; setActive(idx, false); }
        }

        if (toggleBtn) {
          toggleBtn.addEventListener('click', function() {
            syncEnabled = !getSyncEnabled();
            setSyncEnabled(syncEnabled);
            if (syncEnabled) {
              var idx = getCurrentLineIndex(audio.currentTime);
              if (idx != null) { lastActiveIndex = idx; setActive(idx, false); }
            }
          });
        }

        audio.addEventListener('play', function() {
          updateCylindrical();
          if (getSyncEnabled()) {
            var idx = getCurrentLineIndex(audio.currentTime);
            if (idx != null) { lastActiveIndex = idx; setActive(idx, true); }
          }
        });
        audio.addEventListener('pause', updateCylindrical);
        audio.addEventListener('timeupdate', function() {
          if (!getSyncEnabled()) return;
          var index = getCurrentLineIndex(audio.currentTime);
          if (index == null) return;
          var isNew = index !== lastActiveIndex;
          lastActiveIndex = index;
          setActive(index, isNew);
        });
        blocks.forEach(function(el) {
          el.style.cursor = 'pointer';
          el.addEventListener('click', function() {
            var t = parseFloat(el.getAttribute('data-start-time'));
            if (!Number.isNaN(t)) {
              audio.currentTime = t;
              audio.play();
              var idx = Number(el.getAttribute('data-sync-index'));
              lastActiveIndex = idx;
              if (getSyncEnabled()) setActive(idx, true);
            }
          });
        });
      })();
    </script>
  )}
</ChantLayout>
