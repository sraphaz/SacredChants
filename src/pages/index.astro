---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ui } from '../i18n/strings';

const tEn = ui.en;
const tPt = ui.pt;
---

<BaseLayout
  title="Sacred Chants"
  description="A living library of sacred sound traditions. Sacred chants, mantras, prayers, and devotional songs."
>
  <section class="max-w-2xl mx-auto px-4 py-20 text-center">
    <h1 class="font-serif text-4xl md:text-5xl sc-heading mb-4">
      Sacred Chants
    </h1>
    <p class="text-xl text-stone-600 mb-8">
      <span class="locale-en">{tEn.home.tagline}</span>
      <span class="locale-pt">{tPt.home.tagline}</span>
    </p>
    <p class="text-stone-600 mb-12 max-w-lg mx-auto">
      <span class="locale-en">{tEn.home.subtitle}</span>
      <span class="locale-pt">{tPt.home.subtitle}</span>
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/chants" class="locale-en sc-btn-primary inline-block px-6 py-3 rounded-md transition">
        {tEn.home.browseChants}
      </a>
      <a href="/chants?lang=pt" class="locale-pt sc-btn-primary inline-block px-6 py-3 rounded-md transition">
        {tPt.home.browseChants}
      </a>
      <a href="/traditions" class="locale-en sc-btn-secondary inline-block px-6 py-3 rounded-md border border-stone-300 text-stone-700 hover:bg-stone-50 transition">
        {tEn.home.exploreTraditions}
      </a>
      <a href="/traditions?lang=pt" class="locale-pt sc-btn-secondary inline-block px-6 py-3 rounded-md border border-stone-300 text-stone-700 hover:bg-stone-50 transition">
        {tPt.home.exploreTraditions}
      </a>
    </div>
  </section>
</BaseLayout>
