---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import SaveOfflineToggle from '../components/SaveOfflineToggle.astro';
import { ui, getLocaleFromUrl, langQuery, SUPPORTED_LOCALES } from '../i18n/strings';
import { PAGE_SEO } from '../i18n/page-seo';
import { getFullBase } from '../utils/base';
import { buildCanonicalPageUrl } from '../utils/offline-page-url';

const locale = getLocaleFromUrl(Astro.url.searchParams);
const FULL_BASE = getFullBase(Astro.url);
const pageUrlForOffline = buildCanonicalPageUrl(
  Astro.url.origin,
  Astro.url.pathname,
  Astro.url.search
);
const tByLocale = {
  en: ui.en,
  pt: ui.pt,
  es: ui.es,
  it: ui.it,
  hi: ui.hi,
} as const;
const tEn = tByLocale.en;
const tPt = tByLocale.pt;
const tEs = tByLocale.es;
const tIt = tByLocale.it;
const tHi = tByLocale.hi;
---

<BaseLayout
  title="Sacred Chants"
  description={PAGE_SEO[locale].homeDescription}
  locale={locale}
>
  <PageShell variant="hero">
    <!-- 1. Hero -->
    <section class="home-hero" aria-labelledby="home-title">
      <h1 id="home-title" class="home-hero__title sc-heading">
        Sacred Chants
      </h1>
      <p class="home-hero__tagline">
        {SUPPORTED_LOCALES.map((loc) => (
          <span class={`locale-${loc}`}>{tByLocale[loc].home.tagline}</span>
        ))}
      </p>
      <p class="home-hero__intro">
        {SUPPORTED_LOCALES.map((loc) => (
          <span class={`locale-${loc}`}>{tByLocale[loc].home.intro}</span>
        ))}
      </p>
      <div class="flex flex-col items-center gap-4">
        <div class="flex flex-wrap justify-center gap-3">
          {SUPPORTED_LOCALES.map((loc) => (
            <a
              href={`${FULL_BASE}chants/${langQuery(loc)}`}
              class={`locale-${loc} sc-btn-primary home-hero__cta`}
            >
              {tByLocale[loc].home.ctaChants}
            </a>
          ))}
        </div>
        {SUPPORTED_LOCALES.map((loc) => (
          <a
            href={`${FULL_BASE}traditions/${langQuery(loc)}`}
            class={`locale-${loc} text-sm hover:underline`}
            style="color: var(--sc-text-muted);"
          >
            {tByLocale[loc].home.exploreTraditions}
          </a>
        ))}
      </div>
    </section>

    <SaveOfflineToggle
      mode="toolbar"
      class="mb-8"
      storageSlug="__home__"
      pageUrl={pageUrlForOffline}
      toolbarAriaLabel={ui[locale].settings.offlineTitle}
    />

    <!-- 2. Manifesto / vision -->
    <section class="home-section home-prose" aria-labelledby="manifesto-heading">
      <h2 id="manifesto-heading" class="home-section__heading sc-heading">
        <span class="locale-en">{tEn.home.manifestoHeading}</span>
        <span class="locale-pt">{tPt.home.manifestoHeading}</span>
        <span class="locale-es">{tEs.home.manifestoHeading}</span>
        <span class="locale-it">{tIt.home.manifestoHeading}</span>
        <span class="locale-hi">{tHi.home.manifestoHeading}</span>
      </h2>
      <p>
        <span class="locale-en">{tEn.home.manifestoP1}</span>
        <span class="locale-pt">{tPt.home.manifestoP1}</span>
        <span class="locale-es">{tEs.home.manifestoP1}</span>
        <span class="locale-it">{tIt.home.manifestoP1}</span>
        <span class="locale-hi">{tHi.home.manifestoP1}</span>
      </p>
      <p>
        <span class="locale-en">{tEn.home.manifestoP2}</span>
        <span class="locale-pt">{tPt.home.manifestoP2}</span>
        <span class="locale-es">{tEs.home.manifestoP2}</span>
        <span class="locale-it">{tIt.home.manifestoP2}</span>
        <span class="locale-hi">{tHi.home.manifestoP2}</span>
      </p>
      <p>
        <span class="locale-en">{tEn.home.manifestoP3}</span>
        <span class="locale-pt">{tPt.home.manifestoP3}</span>
        <span class="locale-es">{tEs.home.manifestoP3}</span>
        <span class="locale-it">{tIt.home.manifestoP3}</span>
        <span class="locale-hi">{tHi.home.manifestoP3}</span>
      </p>
    </section>

    <!-- 3. Living library -->
    <section class="home-section home-prose" aria-labelledby="library-heading">
      <h2 id="library-heading" class="home-section__heading sc-heading">
        <span class="locale-en">{tEn.home.libraryHeading}</span>
        <span class="locale-pt">{tPt.home.libraryHeading}</span>
        <span class="locale-es">{tEs.home.libraryHeading}</span>
        <span class="locale-it">{tIt.home.libraryHeading}</span>
        <span class="locale-hi">{tHi.home.libraryHeading}</span>
      </h2>
      <p>
        <span class="locale-en">{tEn.home.libraryBody}</span>
        <span class="locale-pt">{tPt.home.libraryBody}</span>
        <span class="locale-es">{tEs.home.libraryBody}</span>
        <span class="locale-it">{tIt.home.libraryBody}</span>
        <span class="locale-hi">{tHi.home.libraryBody}</span>
      </p>
    </section>

    <!-- 4. Shared heritage -->
    <section class="home-section home-prose" aria-labelledby="heritage-heading">
      <h2 id="heritage-heading" class="home-section__heading sc-heading">
        <span class="locale-en">{tEn.home.heritageHeading}</span>
        <span class="locale-pt">{tPt.home.heritageHeading}</span>
        <span class="locale-es">{tEs.home.heritageHeading}</span>
        <span class="locale-it">{tIt.home.heritageHeading}</span>
        <span class="locale-hi">{tHi.home.heritageHeading}</span>
      </h2>
      <p>
        <span class="locale-en">{tEn.home.heritageBody}</span>
        <span class="locale-pt">{tPt.home.heritageBody}</span>
        <span class="locale-es">{tEs.home.heritageBody}</span>
        <span class="locale-it">{tIt.home.heritageBody}</span>
        <span class="locale-hi">{tHi.home.heritageBody}</span>
      </p>
    </section>

    <!-- 5. Closing invitation -->
    <section class="home-closing" aria-labelledby="closing-heading">
      <h2 id="closing-heading" class="home-closing__heading sc-heading">
        <span class="locale-en">{tEn.home.closingHeading}</span>
        <span class="locale-pt">{tPt.home.closingHeading}</span>
        <span class="locale-es">{tEs.home.closingHeading}</span>
        <span class="locale-it">{tIt.home.closingHeading}</span>
        <span class="locale-hi">{tHi.home.closingHeading}</span>
      </h2>
      <p class="home-closing__body">
        <span class="locale-en">{tEn.home.closingBody}</span>
        <span class="locale-pt">{tPt.home.closingBody}</span>
        <span class="locale-es">{tEs.home.closingBody}</span>
        <span class="locale-it">{tIt.home.closingBody}</span>
        <span class="locale-hi">{tHi.home.closingBody}</span>
      </p>
    </section>
  </PageShell>
</BaseLayout>
