---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ui, type Locale } from '../i18n/strings';

const locale = (Astro.url.searchParams.get('lang') === 'pt' ? 'pt' : 'en') as Locale;
const t = ui[locale];
---

<BaseLayout
  title="Sacred Chants"
  description="A living library of sacred sound traditions. Sacred chants, mantras, prayers, and devotional songs."
  locale={locale}
>
  <section class="max-w-2xl mx-auto px-4 py-20 text-center">
    <h1 class="font-serif text-4xl md:text-5xl text-stone-900 mb-4">
      Sacred Chants
    </h1>
    <p class="text-xl text-stone-600 mb-8">
      {t.home.tagline}
    </p>
    <p class="text-stone-600 mb-12 max-w-lg mx-auto">
      {t.home.subtitle}
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href={locale === 'en' ? '/chants' : '/chants?lang=pt'}
        class="inline-block px-6 py-3 rounded-md bg-stone-900 text-white hover:bg-stone-800 transition"
      >
        {t.home.browseChants}
      </a>
      <a
        href={locale === 'en' ? '/traditions' : '/traditions?lang=pt'}
        class="inline-block px-6 py-3 rounded-md border border-stone-300 text-stone-700 hover:bg-stone-50 transition"
      >
        {t.home.exploreTraditions}
      </a>
    </div>
  </section>
</BaseLayout>
